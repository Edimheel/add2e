                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.constitution_base actor.system.bonus_caracteristiques.constitution}}</span>
                    {{#if actor.system.bonus_caracteristiques.constitution}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.constitution 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.constitution}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="constitution" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>PV / niv.</label><input type="text" name="system.con_pv" value="{{actor.system.con_pv}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Choc</label><input type="text" name="system.con_trauma" value="{{actor.system.con_trauma}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Résurrection</label><input type="text" name="system.con_resu" value="{{actor.system.con_resu}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="intelligence" title="Jet d’Intelligence" style="color:#2980b9;"></i>
                  <span class="carac-short">INT</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="intelligence" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="intelligence"
                       title="Base : {{actor.system.intelligence_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.intelligence}}&#10;Total : {{add actor.system.intelligence_base actor.system.bonus_caracteristiques.intelligence}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.intelligence_base actor.system.bonus_caracteristiques.intelligence}}</span>
                    {{#if actor.system.bonus_caracteristiques.intelligence}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.intelligence 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.intelligence}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="intelligence" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Langues</label><input type="text" name="system.int_langues" value="{{actor.system.int_langues}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>% sort</label><input type="text" name="system.int_chance_sort" value="{{actor.system.int_chance_sort}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts min</label><input type="text" name="system.int_sort_min" value="{{actor.system.int_sort_min}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts max</label><input type="text" name="system.int_sort_max" value="{{actor.system.int_sort_max}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>/ niveau</label><input type="text" name="system.int_sort_par_niveau" value="{{actor.system.int_sort_par_niveau}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="sagesse" title="Jet de Sagesse" style="color:#9b59b6;"></i>
                  <span class="carac-short">SAG</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="sagesse" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="sagesse"
                       title="Base : {{actor.system.sagesse_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.sagesse}}&#10;Total : {{add actor.system.sagesse_base actor.system.bonus_caracteristiques.sagesse}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.sagesse_base actor.system.bonus_caracteristiques.sagesse}}</span>
                    {{#if actor.system.bonus_caracteristiques.sagesse}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.sagesse 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.sagesse}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="sagesse" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Bonus magie</label><input type="text" name="system.sag_bm_magie" value="{{actor.system.sag_bm_magie}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts bonus</label><input type="text" name="system.sag_sort_suppl" value="{{actor.system.sag_sort_suppl}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>% échec</label><input type="text" name="system.sag_echec" value="{{actor.system.sag_echec}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="charisme" title="Jet de Charisme" style="color:#e056fd;"></i>
                  <span class="carac-short">CHA</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="charisme" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="charisme"
                       title="Base : {{actor.system.charisme_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.charisme}}&#10;Total : {{add actor.system.charisme_base actor.system.bonus_caracteristiques.charisme}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.charisme_base actor.system.bonus_caracteristiques.charisme}}</span>
                    {{#if actor.system.bonus_caracteristiques.charisme}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.charisme 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.charisme}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="charisme" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Compagnons</label><input type="text" name="system.cha_compagnons" value="{{actor.system.cha_compagnons}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Loyauté</label><input type="text" name="system.cha_loy" value="{{actor.system.cha_loy}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Réaction</label><input type="text" name="system.cha_react" value="{{actor.system.cha_react}}" readonly></div>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

      <aside class="a2e-saves-square-strip a2e-saves-square-side" aria-label="Jets de sauvegarde">
        <div class="a2e-saves-square-title">
          <i class="fas fa-dice-d20"></i>
          <span>Sauv.</span>
        </div>
      <div class="a2e-save-square-grid">
        {{#each saveShortLabels as |saveLabel idx|}}
          <div class="a2e-save-square a2e-save-square-{{idx}}">
            {{#if (eq idx 0)}}<i class="fas fa-skull-crossbones roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 1)}}<i class="fas fa-gem roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 2)}}<i class="fas fa-magic roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 3)}}<i class="fas fa-fire roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 4)}}<i class="fas fa-scroll roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            <div class="a2e-save-square-label">
              {{#if (eq idx 0)}}Paralysie / poison / mort magique{{/if}}
              {{#if (eq idx 1)}}Pétrification / polymorphose{{/if}}
              {{#if (eq idx 2)}}Baguettes et badines{{/if}}
              {{#if (eq idx 3)}}Souffles{{/if}}
              {{#if (eq idx 4)}}Sortilèges{{/if}}
            </div>
            <div class="a2e-save-square-value">
              {{#if ../progressionCourante}}
                {{lookup ../progressionCourante.savingThrows idx}}
              {{else}}
                —
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
      </aside>
    </div>

    <nav class="a2e-tabs sheet-tabs tabs" data-group="primary">
      <a class='item {{#if (eq activeTab "resume")}}active{{/if}}' data-tab="resume" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-id-card"></i> Résumé</a>
      <a class='item {{#if (eq activeTab "combat")}}active{{/if}}' data-tab="combat" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-shield-alt"></i> Combat</a>
      <a class='item {{#if (eq activeTab "capacites")}}active{{/if}}' data-tab="capacites" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-bolt"></i> Capacités</a>
      <a class='item {{#if (eq activeTab "sorts")}}active{{/if}}' data-tab="sorts" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-magic"></i> Sorts</a>
      <a class='item {{#if (eq activeTab "effets")}}active{{/if}}' data-tab="effets" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-sparkles"></i> Effets</a>
      <a class='item {{#if (eq activeTab "equipement")}}active{{/if}}' data-tab="equipement" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-suitcase"></i> Équipement</a>
      <a class='item {{#if (eq activeTab "notes")}}active{{/if}}' data-tab="notes" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-feather-alt"></i> Notes</a>
    </nav>

    <main class="sheet-body">
      <section class='a2e-tab-content tab tab-resume {{#if (eq activeTab "resume")}}active{{/if}}' data-group="primary" data-tab="resume">
        <div class="a2e-summary-dashboard">
          <div>
            <div class="a2e-summary-metrics">
              <div class="a2e-summary-card">
                <i class="fas fa-shield-alt"></i>
                <div>
                  <label>CA</label>
                  <strong>{{combatDefense.ac_totale}}</strong>
                  <small>physique {{combatDefense.ac_naturelle}}</small>
                </div>
              </div>

              <div class="a2e-summary-card">
                <i class="fas fa-crosshairs"></i>
                <div>
                  <label>THAC0</label>
                  <strong>{{combatDefense.thaco}}</strong>
                  <small>attaque de base</small>
                </div>
              </div>

              <div class="a2e-summary-card">
                <i class="fas fa-running"></i>
                <div>
                  <label>Mouvement</label>
                  <strong>{{#if system.movement}}{{system.movement}}{{else}}{{actor.system.movement}}{{/if}} m</strong>
                  <small>déplacement</small>
                </div>
              </div>
            </div>

            <div class="a2e-panel">
              <h2><i class="fas fa-swords"></i> Attaque rapide</h2>
              <div class="a2e-panel-body">
                {{#if actor.system.arme_equipee}}
                  <div class="a2e-summary-attack-list">
                    {{#each listeArmes as |arme|}}
                      {{#if arme.system.equipee}}
                        <div class="a2e-summary-weapon item" data-item-id="{{arme._id}}">
                          <img class="arme-img-attack" data-item-id="{{arme._id}}" src="{{arme.img}}" title="Attaquer avec {{arme.name}}">
                          <div>
                            <div class="a2e-summary-weapon-name">{{arme.name}}</div>
                            <div class="a2e-summary-weapon-meta">
                              <span><b>Dégâts</b> {{arme.system.dégâts.contre_moyen}} / {{arme.system.dégâts.contre_grand}}</span>
                              <span><b>Type</b> {{arme.system.type_degats}}</span>
                              <span><b>Toucher</b> {{../combatDefense.bonus_toucher}}</span>
                              <span><b>Dégâts bonus</b> {{../combatDefense.bonus_degats}}</span>
                            </div>
                          </div>
                          <button type="button" class="a2e-summary-attack-button arme-img-attack" data-item-id="{{arme._id}}">
                            <i class="fas fa-dice-d20"></i>&nbsp;Attaquer
                          </button>
                        </div>
                      {{/if}}
                    {{/each}}
                  </div>
                {{else}}
                  <p class="a2e-muted">Aucune arme équipée.</p>
                {{/if}}
              </div>
            </div>

            <div class="a2e-grid-2">
              <div class="a2e-panel">
                <h2><i class="fas fa-shield-alt"></i> Défense équipée</h2>
                <div class="a2e-panel-body">
                  <div class="a2e-summary-pills">
                    <span class="a2e-summary-pill">Armure : {{{combatDefense.armure}}}</span>
                    <span class="a2e-summary-pill">Bouclier : {{{combatDefense.bouclier}}}</span>
                    <span class="a2e-summary-pill">Heaume : {{{combatDefense.heaume}}}</span>
                  </div>
                </div>
              </div>

              <div class="a2e-panel">
                <h2><i class="fas fa-magic"></i> Préparations</h2>
                <div class="a2e-panel-body">
                  {{#if add2eSpellSummaryRows.length}}
                    <div class="a2e-summary-pills a2e-prep-summary" style="display:flex;flex-direction:column;align-items:flex-start;gap:5px;">
                      {{#each add2eSpellSummaryRows as |row|}}
                        <div class="a2e-prep-list-line" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                          <strong>{{row.label}} :</strong>
                          {{#each row.levels as |lvl|}}
                            <span class="a2e-summary-pill a2e-prep-pill">
                              <b>N{{lvl.spellLevel}}</b>
                              <span>{{lvl.count}} / {{lvl.max}}</span>
                            </span>
                          {{/each}}
                        </div>
                      {{/each}}
                    </div>
                  {{else}}
                    {{#if progressionCourante.spellsPerLevel}}
                      <div class="a2e-summary-pills a2e-prep-summary">
                        {{#each progressionCourante.spellsPerLevel as |slots idx|}}
                          {{#if slots}}
                            {{#with (lookup ../sortsMemorizedByLevel (add idx 1))}}
                              <span class="a2e-summary-pill a2e-prep-pill">
                                <b>N{{add idx 1}}</b>
                                <span>{{count}} / {{max}}</span>
                              </span>
                            {{else}}
                              <span class="a2e-summary-pill a2e-prep-pill">
                                <b>N{{add idx 1}}</b>
                                <span>0 / {{slots}}</span>
                              </span>
                            {{/with}}
                          {{/if}}
                        {{/each}}
                      </div>
                    {{else}}
                      <p class="a2e-muted">Aucun emplacement de sort.</p>
                    {{/if}}
                  {{/if}}
                </div>
              </div>
            </div>
          </div>

          <div>
            <div class="a2e-panel">
              <h2><i class="fas fa-id-card"></i> Classe / race</h2>
              <div class="a2e-panel-body a2e-small">
                <div class="a2e-summary-pills" style="margin-bottom:8px;">
                  <span class="a2e-summary-pill">{{actor.system.race}}</span>
                  <span class="a2e-summary-pill">{{actor.system.classe}} niv. {{actor.system.niveau}}</span>
                  <span class="a2e-summary-pill">{{actor.system.alignement}}</span>
                </div>

                {{#if actor.system.details_race.capacites.length}}
                  <h3>Race</h3>
                  <ul class="a2e-summary-simple-list">
                    {{#each actor.system.details_race.capacites}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ul>
                {{/if}}

                {{#if actor.system.details_classe.specialAbilities.length}}
                  <h3>Classe</h3>
                  <ul class="a2e-summary-simple-list">
                    {{#each actor.system.details_classe.specialAbilities}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ul>
                {{else}}
                  <p class="a2e-muted">Aucune capacité spéciale renseignée.</p>
                {{/if}}
              </div>
            </div>

            <div class="a2e-panel">
              <h2><i class="fas fa-sparkles"></i> Effets actifs</h2>
              <div class="a2e-panel-body">
                {{#if activeEffectsList.length}}
                  <div class="a2e-summary-effects">
                    {{#each activeEffectsList as |eff|}}
                      <div class="a2e-summary-effect">
                        <img src="{{eff.img}}" alt="{{eff.name}}">
                        <div>
                          <strong>{{eff.name}}</strong><br>
                          <small>{{#if eff.duration}}{{eff.duration}}{{else}}Durée permanente ou non renseignée{{/if}}</small>
                        </div>
                      </div>
                    {{/each}}
                  </div>
                {{else}}
                  <p class="a2e-muted">Aucun effet actif.</p>
                {{/if}}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class='a2e-tab-content tab tab-combat {{#if (eq activeTab "combat")}}active{{/if}}' data-group="primary" data-tab="combat">
        <div class="a2e-grid-2">
          <div class="a2e-panel">
            <h2>Défense</h2>
            <div class="a2e-panel-body">
              <table class="a2e-table">
                <tbody>
                  <tr><th>CA naturelle / physique</th><td>{{combatDefense.ac_naturelle}}</td></tr>
                  <tr><th>CA totale</th><td><b>{{combatDefense.ac_totale}}</b></td></tr>
                  <tr><th>Armure</th><td>{{{combatDefense.armure}}}</td></tr>
                  <tr><th>Bouclier</th><td>{{{combatDefense.bouclier}}}</td></tr>
                  <tr><th>Heaume</th><td>{{{combatDefense.heaume}}}</td></tr>
                  <tr><th>Mod. DEX défense</th><td>{{actor.system.dex_def}}</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="a2e-panel">
            <h2>Arme équipée</h2>
            <div class="a2e-panel-body">
              <table class="a2e-table">
                <tbody>
                  <tr><th>Arme</th><td>{{{combatDefense.arme}}}</td></tr>
                  <tr><th>Dégâts</th><td>{{combatDefense.degats}}</td></tr>
                  <tr><th>Bonus toucher</th><td>{{combatDefense.bonus_toucher}}</td></tr>
                  <tr><th>Bonus dégâts</th><td>{{combatDefense.bonus_degats}}</td></tr>
                  <tr><th>THAC0</th><td>{{combatDefense.thaco}}</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="a2e-panel">
          <h2>Armes</h2>
          <div class="a2e-panel-body">
            {{#if listeArmes.length}}
              <table class="a2e-table arme-table">
                <thead>
                  <tr>
                    <th></th>
                    <th>Arme</th>
                    <th>Équipée</th>
                    <th>Dégâts</th>
                    <th>Type</th>
                    <th>Bonus toucher</th>
                    <th>Bonus dégâts</th>
                    <th>Facteur</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each listeArmes as |arme|}}
                    <tr class="item" data-item-id="{{arme._id}}">
                      <td>
                        <img class="arme-img-attack" data-item-id="{{arme._id}}" src="{{arme.img}}" title="Attaquer avec {{arme.name}}" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                      </td>
                      <td><b>{{arme.name}}</b></td>
                      <td>
                        {{#if arme.system.equipee}}
                          <i class="fas fa-check-circle equip-green"></i>
                        {{else}}
                          <i class="fas fa-times-circle equip-red"></i>
                        {{/if}}
                      </td>
                      <td>{{arme.system.dégâts.contre_moyen}} / {{arme.system.dégâts.contre_grand}}</td>
                      <td>{{arme.system.type_degats}}</td>
                      <td>{{arme.system.bonus_hit}}</td>
                      <td>{{arme.system.bonus_dom}}</td>
                      <td>{{arme.system.facteur_rapidité}}</td>
                      <td>
                        <div class="a2e-actions">
                          <a class="item-control item-equip a2e-action-icon a2e-equip-state-icon {{#if arme.system.equipee}}equip-green{{else}}equip-red{{/if}}" data-action="equip" data-item-id="{{arme._id}}" title="{{#if arme.system.equipee}}Équipée — cliquer pour retirer{{else}}Non équipée — cliquer pour équiper{{/if}}">
                            <i class="fas fa-swords"></i>
                          </a>
                          <a class="item-control item-edit a2e-action-icon a2e-action-edit" data-action="edit" data-item-id="{{arme._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                          <a class="item-control item-delete a2e-action-icon a2e-action-delete" data-action="delete" data-item-id="{{arme._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                        </div>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{else}}
              <p class="a2e-muted">Aucune arme.</p>
            {{/if}}
          </div>
        </div>
      
          <div class="a2e-panel">
            <h2>Armures, boucliers et heaumes</h2>
            <div class="a2e-panel-body">
              {{#if listeArmures.length}}
                <table class="a2e-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>CA</th>
                      <th>Bonus CA</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each listeArmures as |armure|}}
                      <tr class="item" data-item-id="{{armure._id}}">
                        <td><b>{{armure.name}}</b></td>
                        <td>{{armure.system.ac}}</td>
                        <td>{{armure.system.bonus_ac}}</td>
                        <td>
                          <div class="a2e-actions">
                            <a class="item-control item-equip a2e-action-icon a2e-equip-state-icon {{#if armure.system.equipee}}equip-green{{else}}equip-red{{/if}}" data-action="equip" data-item-id="{{armure._id}}" title="{{#if armure.system.equipee}}Équipée — cliquer pour retirer{{else}}Non équipée — cliquer pour équiper{{/if}}">
                              <i class="fas fa-shield-alt"></i>
                            </a>
                            <a class="item-control item-edit a2e-action-icon a2e-action-edit" data-action="edit" data-item-id="{{armure._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                            <a class="item-control item-delete a2e-action-icon a2e-action-delete" data-action="delete" data-item-id="{{armure._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                          </div>
                        </td>
                      </tr>
                    {{/each}}
                  </tbody>
                </table>
              {{else}}
                <p class="a2e-muted">Aucune armure.</p>
              {{/if}}
            </div>
          </div>
      </section>

      <section class='a2e-tab-content tab tab-capacites {{#if (eq activeTab "capacites")}}active{{/if}}' data-group="primary" data-tab="capacites">
        <div class="a2e-grid-2">
          <div class="a2e-panel">
            <h2>Capacités activables</h2>
            <div class="a2e-panel-body">
              {{#if actor.system.details_classe.classFeatures.length}}
                {{#each actor.system.details_classe.classFeatures as |feature idx|}}
                  {{#if feature.activable}}
                    <div class="a2e-panel" style="box-shadow:none;">
                      <h3>
                        {{feature.name}}
                        {{#if (gt feature.minLevel ../actor.system.niveau)}}
                          <span class="a2e-muted" style="float:right;">Niveau {{feature.minLevel}}</span>
                        {{else}}
                          <span style="float:right;">{{feature.uses.label}}</span>
                        {{/if}}
                      </h3>
                      <div class="a2e-panel-body a2e-small">
                        {{{feature.description}}}
                        <div class="a2e-actions" style="justify-content:flex-start;margin-top:8px;">
                          <button type="button"
                                  class="a2e-btn blue add2e-feature-use"
                                  data-feature-index="{{idx}}"
                                  data-on-use="{{feature.on_use}}">
                            <i class="fas fa-bolt"></i>&nbsp;Utiliser
                          </button>
                        </div>
                      </div>
                    </div>
                  {{/if}}
                {{/each}}
              {{else}}
                <p class="a2e-muted">Aucune capacité de classe renseignée.</p>
              {{/if}}
            </div>
          </div>

          <div class="a2e-panel">
            <h2>Capacités passives</h2>
            <div class="a2e-panel-body">
              {{#if actor.system.details_classe.classFeatures.length}}
                {{#each actor.system.details_classe.classFeatures as |feature|}}
                  {{#unless feature.activable}}
                    <div class="a2e-panel" style="box-shadow:none;">
                      <h3>
                        {{feature.name}}
                        {{#if (gt feature.minLevel ../actor.system.niveau)}}
                          <span class="a2e-muted" style="float:right;">Niveau {{feature.minLevel}}</span>
                        {{else}}
                          <span style="float:right;">Actif</span>
                        {{/if}}
                      </h3>
                      <div class="a2e-panel-body a2e-small">
                        {{{feature.description}}}
                      </div>
                    </div>
                  {{/unless}}
                {{/each}}
              {{else}}
                <p class="a2e-muted">Aucune capacité passive.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </section>

      <section class='a2e-tab-content tab tab-sorts {{#if (eq activeTab "sorts")}}active{{/if}}' data-group="primary" data-tab="sorts">
        <div class="a2e-panel">
          <h2>Sorts</h2>
          <div class="a2e-panel-body">
            {{#if add2eSpellSummaryRows.length}}
              <div class="a2e-native-spell-summary" style="margin-bottom:8px;display:flex;flex-direction:column;gap:4px;">
                {{#each add2eSpellSummaryRows as |row|}}
                  <div class="a2e-native-spell-summary-line" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                    <strong>{{row.label}} :</strong>
                    {{#each row.levels as |lvl|}}
                      <span class="a2e-summary-pill a2e-prep-pill">N{{lvl.spellLevel}} {{lvl.count}} / {{lvl.max}}</span>
                    {{/each}}
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if add2eSpellLevels.length}}
              {{#each add2eSpellLevels as |levelBlock|}}
                <div class="a2e-panel a2e-spell-level-block" style="box-shadow:none;">
                  <h3 style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <span>Sorts de niveau {{levelBlock.spellLevel}}</span>
                  </h3>
                  <div class="a2e-panel-body">
                    {{#if levelBlock.groups.length}}
                      {{#each levelBlock.groups as |group|}}
                        <div class="a2e-spell-sublist" style="margin-bottom:10px;">
                          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:0 0 5px 0;">
                            <strong>{{group.title}}</strong>
                            {{#if group.counter.max}}
                              <span class="sort-memorize-badge">{{group.counter.count}} / {{group.counter.max}}</span>
                            {{/if}}
                          </div>

                          {{#if group.sorts.length}}
                            <table class="sort-table">
                              <thead>
                                <tr>
                                  <th style="width:150px;">Préparer</th>
                                  <th style="width:42px;"></th>
                                  <th>Sort</th>
                                  <th>École</th>
                                  <th>Actions</th>
                                </tr>
                              </thead>
                              <tbody>
                                {{#each group.sorts as |row|}}
                                  <tr class="sort-row" data-sort-id="{{row.id}}">
                                    <td>
                                      {{#if row.isObjectPower}}
                                        <span class="sort-memorize-badge" title="Charges ou utilisations restantes">Charges {{row.objectPowerCharges}}</span>
                                      {{else}}
                                        {{#if row.isCapacity}}
                                          <span class="sort-memorize-badge">Capacité</span>
                                        {{else}}
                                          {{#with (lookup row.entries 0) as |entry|}}
                                            <a class="a2e-action-icon a2e-action-remove sort-memorize-minus" data-sort-id="{{../id}}" data-spell-entry-key="{{entry.key}}" title="Retirer une préparation"><i class="fas fa-minus-circle"></i></a>
                                            <span class="sort-memorize-badge" title="Préparé comme {{entry.label}}">{{entry.count}}</span>
                                            <a class="a2e-action-icon a2e-action-add sort-memorize-plus" data-sort-id="{{../id}}" data-spell-entry-key="{{entry.key}}" title="Ajouter une préparation"><i class="fas fa-plus-circle"></i></a>
                                          {{else}}
                                            <span class="a2e-muted">Non préparable</span>
                                          {{/with}}
                                        {{/if}}
                                      {{/if}}
                                    </td>
                                    <td class="sort-drag">
                                      <img class="sort-cast-img" data-sort-id="{{row.id}}" src="{{row.img}}" title="Lancer {{row.name}}" draggable="true" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                                    </td>
                                    <td>
                                      <a class="sort-name-link toggle-sort-desc-chat" data-sort-id="{{row.id}}" title="Afficher / masquer la description">{{row.name}}</a>
                                    </td>
                                    <td>{{row.ecole}}</td>
                                    <td>
                                      <div class="a2e-actions">
                                        {{#unless row.isObjectPower}}
                                          <a class="a2e-action-icon a2e-action-edit sort-edit" data-sort-id="{{row.id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                                          <a class="a2e-action-icon a2e-action-delete sort-delete" data-sort-id="{{row.id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                                        {{/unless}}
                                      </div>
                                    </td>
                                  </tr>
                                  <tr id="desc-chat-{{row.id}}" class="sort-description">
                                    <td colspan="5" class="sort-description-fullcell">
                                      <div class="a2e-small sort-description-content">
                                        {{{row.description}}}
                                        {{#if row.composantes}}<div><b>Composantes :</b> {{row.composantes}}</div>{{/if}}
                                        {{#if row.temps_incantation}}<div><b>Incantation :</b> {{row.temps_incantation}}</div>{{/if}}
                                        {{#if row.portee}}<div><b>Portée :</b> {{formatSortChamp row.portee}}</div>{{/if}}
                                        {{#if row.duree}}<div><b>Durée :</b> {{formatSortChamp row.duree}}</div>{{/if}}
                                      </div>
                                    </td>
                                  </tr>
                                {{/each}}
                              </tbody>
                            </table>
                          {{else}}
                            <p class="a2e-muted" style="margin:0 0 6px 0;">Aucune entrée.</p>
                          {{/if}}
                        </div>
                      {{/each}}
                    {{else}}
                      <p class="a2e-muted">Aucune entrée de niveau {{levelBlock.spellLevel}}.</p>
                    {{/if}}
                  </div>
                </div>
              {{/each}}
            {{else}}
              {{#if niveauxSorts.length}}
                {{#each niveauxSorts as |niv|}}
                  <div class="a2e-panel" style="box-shadow:none;">
                    <h3>
                      Niveau {{niv}}
                      {{#with (lookup ../sortsMemorizedByLevel niv)}}
                        <span class="sort-memorize-badge">Sorts : {{count}} / {{max}}</span>
                      {{/with}}
                    </h3>
                    <div class="a2e-panel-body">
                      <table class="sort-table">
                        <thead>
                          <tr>
                            <th style="width:130px;">Préparer</th>
                            <th style="width:42px;"></th>
                            <th>Sort</th>
                            <th>École</th>
                            <th>Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          {{#each (lookup ../sortsParNiveau niv) as |sort|}}
                            <tr class="sort-row">
                              <td>
                                <a class="a2e-action-icon a2e-action-remove sort-memorize-minus" data-sort-id="{{sort._id}}" title="Retirer une préparation"><i class="fas fa-minus-circle"></i></a>
                                <span class="sort-memorize-badge">{{getFlag sort "add2e.memorizedCount"}}</span>
                                <a class="a2e-action-icon a2e-action-add sort-memorize-plus" data-sort-id="{{sort._id}}" title="Ajouter une préparation"><i class="fas fa-plus-circle"></i></a>
                              </td>
                              <td class="sort-drag">
                                <img class="sort-cast-img" data-sort-id="{{sort._id}}" src="{{sort.img}}" title="Lancer {{sort.name}}" draggable="true" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                              </td>
                              <td>
                                <a class="sort-name-link toggle-sort-desc-chat" data-sort-id="{{sort._id}}" title="Afficher / masquer la description">{{sort.name}}</a>
                              </td>
                              <td>{{sort.system.école}}</td>
                              <td>
                                <div class="a2e-actions">
                                  <a class="a2e-action-icon a2e-action-edit sort-edit" data-sort-id="{{sort._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                                  <a class="a2e-action-icon a2e-action-delete sort-delete" data-sort-id="{{sort._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                                </div>
                              </td>
                            </tr>
                            <tr id="desc-chat-{{sort._id}}" class="sort-description">
                              <td colspan="5" class="sort-description-fullcell">
                                <div class="a2e-small sort-description-content">
                                  {{{sort.system.description}}}
                                  {{#if sort.system.composantes}}<div><b>Composantes :</b> {{sort.system.composantes}}</div>{{/if}}
                                  {{#if sort.system.temps_incantation}}<div><b>Incantation :</b> {{sort.system.temps_incantation}}</div>{{/if}}
                                  {{#if sort.system.portée}}<div><b>Portée :</b> {{formatSortChamp sort.system.portée}}</div>{{/if}}
                                  {{#if sort.system.durée}}<div><b>Durée :</b> {{formatSortChamp sort.system.durée}}</div>{{/if}}
                                </div>
                              </td>
                            </tr>
                          {{/each}}
                        </tbody>
                      </table>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <p class="a2e-muted">Aucun sort disponible.</p>
              {{/if}}
            {{/if}}
          </div>
        </div>
      </section>

      <section class='a2e-tab-content tab tab-effets {{#if (eq activeTab "effets")}}active{{/if}}' data-group="primary" data-tab="effets">
        <div class="a2e-panel">
          <h2>Effets actifs</h2>
          <div class="a2e-panel-body">
            {{#if activeEffectsList.length}}
              <table class="a2e-table a2e-effects-table">
                <thead>
                  <tr>
                    <th style="width:42px;"></th>
                    <th>Effet</th>
                    <th>Source</th>
                    <th>Durée</th>
                    <th>Description</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each activeEffectsList as |eff|}}
                    <tr>
                      <td><img src="{{eff.img}}" alt="{{eff.name}}" style="width:30px;height:30px;border-radius:5px;object-fit:cover;"></td>
                      <td><b>{{eff.name}}</b></td>
                      <td>{{eff.sourceName}}</td>
                      <td>{{eff.duration}}</td>
                      <td class="effect-description a2e-small">{{{eff.description}}}</td>
                      <td>
                        <div class="a2e-actions">
                          <a class="a2e-action-icon a2e-action-edit effect-edit" data-effect-id="{{eff.id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                          <a class="a2e-action-icon a2e-action-delete effect-delete" data-effect-id="{{eff.id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                        </div>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{else}}
              <p class="a2e-muted">Aucun effet actif.</p>
            {{/if}}
          </div>
        </div>
      </section>

      <section class='a2e-tab-content tab tab-equipement {{#if (eq activeTab "equipement")}}active{{/if}}' data-group="primary" data-tab="equipement">
        <div class="a2e-grid-2">
          <div class="a2e-panel">
            <h2>Objets</h2>
            <div class="a2e-panel-body">
              <a class="a2e-action-icon a2e-action-add objet-create" title="Créer un objet" style="margin-bottom:8px;font-size:1.2em;"><i class="fas fa-plus-circle"></i></a>

              {{#if listeObjets.length}}
                <table class="a2e-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>Qté</th>
                      <th>Poids</th>
                      <th>Équipé</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each listeObjets as |objet|}}
                      <tr class="item" data-item-id="{{objet._id}}" data-itemId="{{objet._id}}">
                        <td><b>{{objet.name}}</b></td>
                        <td>{{objet.system.quantite}}</td>
                        <td>{{objet.system.poids}}</td>
                        <td>
                          {{#if objet.system.equipee}}
                            <i class="fas fa-check-circle equip-green"></i>
                          {{else}}
                            <i class="fas fa-times-circle equip-red"></i>
                          {{/if}}
                        </td>
                        <td>
                          <div class="a2e-actions">
                            <a class="item-control item-equip a2e-action-icon {{#if objet.system.equipee}}a2e-action-unequip{{else}}a2e-action-equip{{/if}}" data-action="equip" data-item-id="{{objet._id}}" title="{{#if objet.system.equipee}}Retirer{{else}}Équiper{{/if}}">
                              {{#if objet.system.equipee}}<i class="fas fa-minus-circle"></i>{{else}}<i class="fas fa-plus-circle"></i>{{/if}}
                            </a>
                            <a class="item-control item-edit a2e-action-icon a2e-action-edit" data-action="edit" data-item-id="{{objet._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                            <a class="item-control item-delete a2e-action-icon a2e-action-delete" data-action="delete" data-item-id="{{objet._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                          </div>
                        </td>
                      </tr>
                    {{/each}}
                  </tbody>
                </table>
                <p class="a2e-small"><b>Poids total objets :</b> {{poidsTotalObjets}}</p>
              {{else}}
                <p class="a2e-muted">Aucun objet.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </section>

      <section class='a2e-tab-content tab tab-notes {{#if (eq activeTab "notes")}}active{{/if}}' data-group="primary" data-tab="notes">
        <div class="a2e-grid-2">
          <div class="a2e-panel">
            <h2>Description de race</h2>
            <div class="a2e-panel-body a2e-small">
              {{#if actor.system.details_race.description_longue}}
                {{{actor.system.details_race.description_longue}}}
              {{else}}
                {{{actor.system.details_race.description}}}
              {{/if}}
            </div>
          </div>

          <div class="a2e-panel">
            <h2>Description de classe</h2>
            <div class="a2e-panel-body a2e-small">
              {{{actor.system.details_classe.description}}}
              {{#if actor.system.details_classe.ruleNotes.length}}
                <ul>
                  {{#each actor.system.details_classe.ruleNotes}}
                    <li>{{this}}</li>
                  {{/each}}
                </ul>
              {{/if}}
            </div>
          </div>
        </div>

        <div class="a2e-panel">
          <h2>Notes du personnage</h2>
          <div class="a2e-panel-body">
            <textarea name="system.notes" rows="8">{{actor.system.notes}}</textarea>
          </div>
        </div>
      </section>
    </main>
  </div>
</form>
