    "specialAbilities": [
      {
        "level": 1,
        "nom": "Combat à mains nues",
        "description": "Le moine inflige des dégâts croissants à mains nues selon son niveau, ignore certaines résistances et peut assommer ses adversaires."
      },
      {
        "level": 1,
        "nom": "Défense naturelle",
        "description": "Ajoute un bonus à la Classe d’Armure à chaque niveau pair (jusqu’à +8 au niveau 16)."
      },
      {
        "level": 1,
        "nom": "Vitesse surnaturelle",
        "description": "Déplacement accru (jusqu’à x2 la vitesse de base au niveau 9)."
      },
      {
        "level": 3,
        "nom": "Résistance mentale",
        "description": "Jet de sauvegarde amélioré contre la magie mentale et le contrôle mental."
      },
      {
        "level": 4,
        "nom": "Chute amortie",
        "description": "Peut ignorer les dégâts de chute si proche d’un mur."
      },
      {
        "level": 5,
        "nom": "Immunité aux maladies",
        "description": "Immunité totale à partir du niveau 5."
      },
      {
        "level": 9,
        "nom": "Immunité au poison",
        "description": "À partir du niveau 9, le moine devient immunisé au poison."
      }
    ],
    "notes": "Le moine ne peut utiliser d’armure ni de bouclier, doit rester loyal. Il progresse rapidement mais ne peut utiliser la plupart des objets magiques. Voir Manuel des Joueurs AD&D2."
  },
