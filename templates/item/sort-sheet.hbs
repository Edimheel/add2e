<form class="{{cssClass}} add2e-item-v2-sheet add2e-sort-sheet" autocomplete="off">
  <style>
    .add2e-sort-sheet{--gold:#d0b16b;--panel:#fffdf7;--soft:#fff8df;--accent:#5d3f91;height:100%;min-height:0;display:flex;flex-direction:column;overflow:hidden;background:linear-gradient(135deg,#f8efd7 0%,#efe0c0 100%);color:#2f241c}.add2e-sort-sheet *{box-sizing:border-box}.add2e-sort-sheet .sheet-header{display:flex;gap:12px;align-items:flex-start;padding:10px;border-bottom:1px solid var(--gold);background:rgba(255,248,224,.72);flex:0 0 auto}.add2e-sort-sheet .profile-img{width:96px;height:96px;object-fit:cover;border:1px solid #7a5a28;border-radius:6px;background:#111;cursor:pointer}.add2e-sort-sheet .header-fields{flex:1;display:grid;gap:7px;min-width:0}.add2e-sort-sheet h1{margin:0}.add2e-sort-sheet input,.add2e-sort-sheet textarea,.add2e-sort-sheet select{width:100%;border:1px solid #b9a15d;border-radius:5px;background:#fffaf0;color:#1d1606;padding:5px 7px}.add2e-sort-sheet label span{display:block;font-weight:800;color:#6f4b12;font-size:.78rem;text-transform:uppercase;letter-spacing:.02em;margin-bottom:2px}.add2e-sort-sheet .grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:7px}.add2e-sort-sheet .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:7px}.add2e-sort-sheet .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:7px}.add2e-sort-sheet .sheet-tabs{display:flex;gap:4px;padding:8px 10px 0;margin:0;background:rgba(250,242,216,.85);border-bottom:1px solid var(--gold);overflow-x:auto;flex:0 0 auto}.add2e-sort-sheet .sheet-tabs .item{padding:7px 12px;border:1px solid var(--gold);border-bottom:0;border-radius:7px 7px 0 0;background:#fffdf4;color:#6f4b12;font-weight:900;text-decoration:none;white-space:nowrap;cursor:pointer}.add2e-sort-sheet .sheet-tabs .item.active{background:linear-gradient(180deg,#6a3c99,#4a2372);color:#fff;border-color:#4a2372}.add2e-sort-sheet .sheet-body{flex:1 1 auto;min-height:0;overflow:auto;padding:12px}.add2e-sort-sheet .content.hidden{display:none!important}.add2e-sort-sheet .content.active{display:block}.add2e-sort-sheet fieldset{border:1px solid var(--gold);border-radius:8px;background:var(--panel);padding:10px;margin:0 0 12px}.add2e-sort-sheet legend{font-weight:900;color:#6f4b12;padding:0 6px}.add2e-sort-sheet textarea{min-height:130px;resize:vertical}.add2e-sort-sheet textarea.add2e-components-textarea{min-height:95px}.add2e-sort-sheet .note{font-size:.85em;color:#6f6040;margin-top:4px}.add2e-sort-sheet table{width:100%;border-collapse:collapse;background:#fffdf6}.add2e-sort-sheet th,.add2e-sort-sheet td{border:1px solid #dac276;padding:5px 6px;color:#2f250c}.add2e-sort-sheet th{background:#ead99d;color:#55390d;font-weight:900;text-align:left}.add2e-sort-sheet .checkline{display:flex;align-items:center;gap:8px;border:1px solid #dac276;border-radius:6px;background:#fff8df;padding:7px 8px}.add2e-sort-sheet .checkline input{width:auto}.add2e-sort-sheet .checkline span{margin:0;font-size:.78rem;color:#6f4b12;font-weight:900;text-transform:uppercase}
  </style>
  <header class="sheet-header">
    <img class="profile-img" src="{{img}}" data-edit="img" title="{{item.name}}"/>
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Nom du sort" style="font-size:1.3rem;font-weight:900;"/></h1>
      <div class="grid-3">
        <label><span>Classe</span><input type="text" name="system.classe" value="{{system.classe}}"/></label>
        <label><span>École</span><input type="text" name="system.école" value="{{system.école}}"/></label>
        <label><span>Niveau</span><input type="number" name="system.niveau" value="{{system.niveau}}"/></label>
      </div>
      <div class="grid-4">
        <label><span>Composantes</span><input type="text" name="system.composantes" value="{{system.composantes}}" placeholder="V, S, M"/></label>
        <label><span>Jet sauvegarde</span><input type="text" name="system.jet_sauvegarde" value="{{system.jet_sauvegarde}}"/></label>
        <label><span>Liste(s)</span><input type="text" name="system.spellLists" value="{{system.spellLists}}"/></label>
        <label><span>Type</span><input type="text" name="system.type" value="{{system.type}}"/></label>
      </div>
    </div>
  </header>
  <nav class="tabs sheet-tabs" data-group="primary">
    <a class="item active" data-tab="resume">Résumé</a>
    <a class="item" data-tab="composants">Composants</a>
    <a class="item" data-tab="parametres">Paramètres</a>
    <a class="item" data-tab="automation">Automatisation</a>
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="effets">Effets</a>
  </nav>
  <section class="sheet-body">
    <div class="content active" data-tab="resume">
      <fieldset><legend>Informations principales</legend>
        <div class="grid-3">
          <label><span>Portée</span><input type="text" name="system.portée.valeur" value="{{system.portée.valeur}}" placeholder="0, 30, toucher"/></label>
          <label><span>Unité portée</span><input type="text" name="system.portée.unite" value="{{system.portée.unite}}" placeholder="m, cases, toucher"/></label>
          <label><span>Temps incantation</span><input type="text" name="system.temps_incantation.valeur" value="{{system.temps_incantation.valeur}}"/></label>
        </div>
        <div class="grid-3" style="margin-top:8px;">
          <label><span>Unité incantation</span><input type="text" name="system.temps_incantation.unite" value="{{system.temps_incantation.unite}}"/></label>
          <label><span>Durée</span><input type="text" name="system.durée.valeur" value="{{system.durée.valeur}}"/></label>
          <label><span>Unité durée</span><input type="text" name="system.durée.unite" value="{{system.durée.unite}}"/></label>
        </div>
      </fieldset>
      <fieldset><legend>Zone d'effet</legend>
        <div class="grid-3">
          <label><span>Valeur</span><input type="text" name="system.zone_effet.valeur" value="{{system.zone_effet.valeur}}"/></label>
          <label><span>Unité</span><input type="text" name="system.zone_effet.unite" value="{{system.zone_effet.unite}}"/></label>
          <label><span>Nombre</span><input type="text" name="system.number" value="{{system.number}}"/></label>
        </div>
      </fieldset>
    </div>

    <div class="content hidden" data-tab="composants">
      <fieldset><legend>Composantes du sort</legend>
        <div class="grid-3">
          <label><span>Composantes</span><input type="text" name="system.composantes" value="{{system.composantes}}" placeholder="V, S, M"/></label>
          <label><span>Source composants</span><input type="text" name="system.composants_materiels_source" value="{{system.composants_materiels_source}}" placeholder="Manuel des joueurs"/></label>
          <label class="checkline" title="À cocher si le sort contient M mais que le composant matériel reste à compléter."><input type="checkbox" name="system.composants_materiels_a_renseigner" {{#if system.composants_materiels_a_renseigner}}checked{{/if}}/><span>Matériel à renseigner</span></label>
        </div>
        <label style="margin-top:8px;display:block;"><span>Composants matériels</span><textarea class="add2e-components-textarea" name="system.composants_materiels" rows="5" placeholder="Un composant par ligne, ou séparé par des virgules/points-virgules. Laisser vide si le sort n’a pas de composante M.">{{spellMaterialComponents item}}</textarea></label>
        <div class="grid-2" style="margin-top:8px;">
          <label><span>Référence / page</span><input type="text" name="system.composants_materiels_reference" value="{{system.composants_materiels_reference}}" placeholder="Manuel des joueurs, sort ..."/></label>
          <label><span>Vérification recommandée</span><input type="text" name="system.composants_materiels_verification_recommandee" value="{{system.composants_materiels_verification_recommandee}}" placeholder="oui / non / note"/></label>
        </div>
        <label style="margin-top:8px;display:block;"><span>Note composant matériel</span><textarea class="add2e-components-textarea" name="system.composants_materiels_note" rows="4" placeholder="Notes de vérification, ambiguïtés OCR, source alternative, précision de consommation, etc.">{{system.composants_materiels_note}}</textarea></label>
        <div class="note">Ce bloc permet de corriger manuellement les sorts avec composante M. Pour un sort sans composante matérielle, laisser la liste vide et décocher “Matériel à renseigner”.</div>
      </fieldset>
    </div>

    <div class="content hidden" data-tab="parametres">
      <fieldset><legend>Champs complémentaires</legend>
        <div class="grid-3">
          <label><span>Régime</span><input type="text" name="system.diet" value="{{system.diet}}"/></label>
          <label><span>Table rencontre</span><input type="text" name="system.encounterTable" value="{{system.encounterTable}}"/></label>
          <label><span>Source</span><input type="text" name="system.source" value="{{system.source}}"/></label>
        </div>
      </fieldset>
    </div>
    <div class="content hidden" data-tab="automation">
      <fieldset><legend>Script On Use</legend>
        <label><span>system.onuse</span><input type="text" name="system.onuse" value="{{system.onuse}}" placeholder="scripts/sorts/soins_mineurs.js"/></label>
        <div class="note">Champ principal lu par l'automatisation actuelle.</div>
        <label style="margin-top:8px;"><span>system.onUse</span><input type="text" name="system.onUse" value="{{system.onUse}}" placeholder="scripts/sorts/soins_mineurs.js"/></label>
        <label style="margin-top:8px;"><span>system.on_use</span><input type="text" name="system.on_use" value="{{system.on_use}}" placeholder="systems/add2e/scripts/sorts/soins_mineurs.js"/></label>
        <label style="margin-top:8px;"><span>system.onUseCode</span><textarea name="system.onUseCode" rows="8" placeholder="// Code JavaScript direct optionnel">{{system.onUseCode}}</textarea></label>
      </fieldset>
    </div>
    <div class="content hidden" data-tab="description">
      <fieldset><legend>Description</legend><textarea name="system.description" rows="12">{{system.description}}</textarea></fieldset>
      <fieldset><legend>Description réelle / Manuel</legend><textarea name="system.description_reelle" rows="12" placeholder="Description exacte ou normalisée issue du Manuel du joueur">{{system.description_reelle}}</textarea></fieldset>
      <fieldset><legend>Description source</legend><input type="text" name="system.description_source" value="{{system.description_source}}" placeholder="Manuel des joueurs AD&D 2e"/></fieldset>
    </div>
    <div class="content hidden" data-tab="effets">
      {{#if item.effects.contents.length}}
      <table><thead><tr><th>Nom</th><th style="text-align:center;">Transféré</th><th style="text-align:center;">Actif</th><th style="text-align:center;">Durée rounds</th></tr></thead><tbody>
        {{#each item.effects.contents as |eff|}}
        <tr><td>{{eff.name}}</td><td style="text-align:center;">{{#if eff.transfer}}Oui{{else}}Non{{/if}}</td><td style="text-align:center;">{{#unless eff.disabled}}Oui{{else}}Non{{/unless}}</td><td style="text-align:center;">{{eff.duration.rounds}}</td></tr>
        {{/each}}
      </tbody></table>
      {{else}}<p>Aucun effet actif embarqué.</p>{{/if}}
    </div>
  </section>
</form>