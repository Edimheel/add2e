<form class="{{cssClass}} add2e-item-v2-sheet add2e-sort-sheet" autocomplete="off">
  <style>
    .add2e-sort-sheet{--gold:#d0b16b;--panel:#fffdf7;--soft:#fff8df;--accent:#5d3f91;height:100%;min-height:0;display:flex;flex-direction:column;overflow:hidden;background:linear-gradient(135deg,#f8efd7 0%,#efe0c0 100%);color:#2f241c}.add2e-sort-sheet *{box-sizing:border-box}.add2e-sort-sheet .sheet-header{display:flex;gap:12px;align-items:center;padding:10px;border-bottom:1px solid var(--gold);background:rgba(255,248,224,.72);flex:0 0 auto}.add2e-sort-sheet .profile-img{width:84px;height:84px;object-fit:cover;border:1px solid #7a5a28;border-radius:6px;background:#111;cursor:pointer}.add2e-sort-sheet .header-fields{flex:1;display:grid;gap:7px;min-width:0}.add2e-sort-sheet h1{margin:0}.add2e-sort-sheet input,.add2e-sort-sheet textarea,.add2e-sort-sheet select{width:100%;border:1px solid #b9a15d;border-radius:5px;background:#fffaf0;color:#1d1606;padding:5px 7px}.add2e-sort-sheet textarea[readonly]{background:#f8f1df;color:#3d321f}.add2e-sort-sheet label span{display:block;font-weight:800;color:#6f4b12;font-size:.78rem;text-transform:uppercase;letter-spacing:.02em;margin-bottom:2px}.add2e-sort-sheet .grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:7px}.add2e-sort-sheet .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:7px}.add2e-sort-sheet .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:7px}.add2e-sort-sheet .sheet-tabs{display:flex;gap:4px;padding:8px 10px 0;margin:0;background:rgba(250,242,216,.85);border-bottom:1px solid var(--gold);overflow-x:auto;flex:0 0 auto}.add2e-sort-sheet .sheet-tabs .item{padding:7px 12px;border:1px solid var(--gold);border-bottom:0;border-radius:7px 7px 0 0;background:#fffdf4;color:#6f4b12;font-weight:900;text-decoration:none;white-space:nowrap;cursor:pointer}.add2e-sort-sheet .sheet-tabs .item.active{background:linear-gradient(180deg,#6a3c99,#4a2372);color:#fff;border-color:#4a2372}.add2e-sort-sheet .sheet-body{flex:1 1 auto;min-height:0;overflow:auto;padding:12px}.add2e-sort-sheet .content.hidden{display:none!important}.add2e-sort-sheet .content.active{display:block}.add2e-sort-sheet fieldset{border:1px solid var(--gold);border-radius:8px;background:var(--panel);padding:10px;margin:0 0 12px}.add2e-sort-sheet legend{font-weight:900;color:#6f4b12;padding:0 6px}.add2e-sort-sheet textarea{min-height:130px;resize:vertical}.add2e-sort-sheet textarea.add2e-components-textarea{min-height:95px}.add2e-sort-sheet textarea.add2e-tech-json{min-height:360px;font-family:monospace;font-size:.82rem;line-height:1.35;white-space:pre;resize:vertical}.add2e-sort-sheet .note{font-size:.85em;color:#6f6040;margin-top:4px}.add2e-sort-sheet .summary-badges{display:flex;flex-wrap:wrap;gap:6px}.add2e-sort-sheet .badge{display:inline-flex;align-items:center;gap:4px;border:1px solid #c9aa5c;border-radius:999px;background:#fff8df;color:#5d3f16;font-weight:900;font-size:.8rem;padding:4px 9px}.add2e-sort-sheet table{width:100%;border-collapse:collapse;background:#fffdf6}.add2e-sort-sheet th,.add2e-sort-sheet td{border:1px solid #dac276;padding:5px 6px;color:#2f250c;vertical-align:top}.add2e-sort-sheet th{background:#ead99d;color:#55390d;font-weight:900;text-align:left}.add2e-sort-sheet .checkline{display:flex;align-items:center;gap:8px;border:1px solid #dac276;border-radius:6px;background:#fff8df;padding:7px 8px}.add2e-sort-sheet .checkline input{width:auto}.add2e-sort-sheet .checkline span{margin:0;font-size:.78rem;color:#6f4b12;font-weight:900;text-transform:uppercase}.add2e-sort-sheet .readonly-box{border:1px solid #dac276;border-radius:6px;background:#fffaf0;padding:7px;white-space:pre-wrap;min-height:32px}.add2e-sort-sheet code{font-family:monospace;font-size:.9em;color:#4a2372}
  </style>
  <header class="sheet-header">
    <img class="profile-img" src="{{img}}" data-edit="img" title="{{item.name}}"/>
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Nom du sort" style="font-size:1.3rem;font-weight:900;"/></h1>
      <div class="summary-badges">
        <span class="badge">{{system.classe}}</span>
        <span class="badge">Niveau {{system.niveau}}</span>
        <span class="badge">{{system.ecole}}</span>
        <span class="badge">{{system.composantes}}</span>
      </div>
    </div>
  </header>
  <nav class="tabs sheet-tabs" data-group="primary">
    <a class="item active" data-tab="resume">Résumé</a>
    <a class="item" data-tab="composants">Composants</a>
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="effets">Effets</a>
    <a class="item" data-tab="technique">Technique</a>
  </nav>
  <section class="sheet-body">
    <div class="content active" data-tab="resume">
      <fieldset><legend>Identité</legend>
        <div class="grid-4">
          <label><span>Classe</span><input type="text" name="system.classe" value="{{system.classe}}"/></label>
          <label><span>Liste(s)</span><input type="text" name="system.spellLists" value="{{system.spellLists}}"/></label>
          <label><span>Niveau</span><input type="number" name="system.niveau" value="{{system.niveau}}"/></label>
          <label><span>École</span><input type="text" name="system.ecole" value="{{system.ecole}}"/></label>
        </div>
      </fieldset>

      <fieldset><legend>Règles de lancement</legend>
        <div class="grid-3">
          <label><span>Portée</span><input type="text" name="system.portee" value="{{system.portee}}" placeholder="0, 30, toucher"/></label>
          <label><span>Durée</span><input type="text" name="system.duree" value="{{system.duree}}"/></label>
          <label><span>Temps incantation</span><input type="text" name="system.temps_incantation" value="{{system.temps_incantation}}"/></label>
        </div>
        <div class="grid-3" style="margin-top:8px;">
          <label><span>Zone d'effet</span><input type="text" name="system.zone_effet" value="{{system.zone_effet}}"/></label>
          <label><span>Cible</span><input type="text" name="system.cible" value="{{system.cible}}"/></label>
          <label><span>Jet sauvegarde</span><input type="text" name="system.jet_sauvegarde" value="{{system.jet_sauvegarde}}"/></label>
        </div>
      </fieldset>
    </div>

    <div class="content hidden" data-tab="composants">
      <fieldset><legend>Composantes</legend>
        <div class="grid-3">
          <label><span>V / S / M</span><input type="text" name="system.composantes" value="{{system.composantes}}" placeholder="V, S, M"/></label>
          <label><span>Source</span><input type="text" name="system.composants_materiels_source" value="{{system.composants_materiels_source}}" placeholder="Manuel des joueurs"/></label>
          <label class="checkline" title="À cocher si le sort contient M mais que le composant matériel reste à compléter."><input type="checkbox" name="system.composants_materiels_a_renseigner" {{#if system.composants_materiels_a_renseigner}}checked{{/if}}/><span>Matériel à renseigner</span></label>
        </div>
        <label style="margin-top:8px;display:block;"><span>Composants matériels</span><textarea class="add2e-components-textarea" name="system.composants_materiels" rows="5" placeholder="Un composant par ligne, ou séparé par des virgules/points-virgules. Laisser vide si le sort n’a pas de composante M.">{{spellMaterialComponents item}}</textarea></label>
        <div class="grid-2" style="margin-top:8px;">
          <label><span>Référence / page</span><input type="text" name="system.composants_materiels_reference" value="{{system.composants_materiels_reference}}"/></label>
          <label><span>Vérification recommandée</span><input type="text" name="system.composants_materiels_verification_recommandee" value="{{system.composants_materiels_verification_recommandee}}"/></label>
        </div>
        <label style="margin-top:8px;display:block;"><span>Note composant matériel</span><textarea class="add2e-components-textarea" name="system.composants_materiels_note" rows="4">{{system.composants_materiels_note}}</textarea></label>
      </fieldset>
    </div>

    <div class="content hidden" data-tab="description">
      <fieldset><legend>Description</legend><textarea name="system.description" rows="14">{{system.description}}</textarea></fieldset>
    </div>

    <div class="content hidden" data-tab="effets">
      <fieldset><legend>Profil d'effets structuré</legend>
        <label><span>system.effectProfile</span><textarea class="add2e-tech-json" readonly rows="14">{{json system.effectProfile}}</textarea></label>
        <div class="note">Ce bloc décrit les effets du sort. Il reste distinct des ActiveEffects Foundry ci-dessous.</div>
      </fieldset>

      <fieldset><legend>ActiveEffects Foundry embarqués</legend>
        {{#if item.effects.contents.length}}
        <table><thead><tr><th>Nom</th><th style="text-align:center;">Transféré</th><th style="text-align:center;">Actif</th><th style="text-align:center;">Durée rounds</th></tr></thead><tbody>
          {{#each item.effects.contents as |eff|}}
          <tr><td>{{eff.name}}</td><td style="text-align:center;">{{#if eff.transfer}}Oui{{else}}Non{{/if}}</td><td style="text-align:center;">{{#unless eff.disabled}}Oui{{else}}Non{{/unless}}</td><td style="text-align:center;">{{eff.duration.rounds}}</td></tr>
          {{/each}}
        </tbody></table>
        {{else}}<p>Aucun effet actif embarqué.</p>{{/if}}
      </fieldset>
    </div>

    <div class="content hidden" data-tab="technique">
      <fieldset><legend>Automatisation</legend>
        <label><span>system.onUse</span><input type="text" name="system.onUse" value="{{system.onUse}}" placeholder="systems/add2e/scripts/sorts/soins-mineurs.js"/></label>
        <label style="margin-top:8px;display:block;"><span>system.onUseCode</span><textarea name="system.onUseCode" rows="6" placeholder="// Code JavaScript direct optionnel">{{system.onUseCode}}</textarea></label>
      </fieldset>

      <fieldset><legend>Tous les champs system</legend>
        <textarea class="add2e-tech-json" readonly rows="18">{{json system}}</textarea>
        <div class="note">Vue technique complète. Les champs principaux sont édités dans les autres onglets ; ce bloc sert au contrôle rapide de la structure JSON.</div>
      </fieldset>
    </div>
  </section>
</form>
