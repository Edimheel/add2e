<section>
  {{!-- ===================================================== --}}
{{!-- RÉCAP SORTS (mémorisés / dispo) PAR NIVEAU --}}
{{!-- ===================================================== --}}
{{#if niveauxSorts.length}}
  <div class="sort-recap"
       style="margin:0.35em 0 0.9em; padding:0.55em 0.8em; border-radius:10px;
              background:#f7f4ff; box-shadow:0 1px 6px #d1cbe2aa;">

    <div style="font-weight:700; color:#6a3c99; margin-bottom:0.35em;">
      Récapitulatif des sorts (mémorisés / disponibles)
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:0.5em 0.7em; align-items:center;">
      {{#each niveauxSorts as |niv|}}
        {{#with (lookup ../sortsMemorizedByLevel niv) as |memo|}}
          <span style="display:inline-flex; align-items:center; gap:0.35em;
                       background:#fff; border:1px solid #e3ddf2; border-radius:999px;
                       padding:0.2em 0.55em; font-size:0.95em;">
            <span style="color:#7c39c3; font-weight:800;">N{{niv}}</span>

            {{!-- Cas multi-sources (Ranger / multiclass Druide+Magicien) --}}
            <span style="color:#2c3e50;">
  <b>{{memo.count}}</b>/<b>{{memo.max}}</b>
</span>

          </span>
        {{/with}}
      {{/each}}
    </div>
  </div>
{{/if}}

  <h2>Sorts connus / mémorisés</h2>
  {{#if niveauxSorts.length}}
    {{#each niveauxSorts as |niv|}}
      <div class="sort-niveau-block">
        <h3 style="margin-top:0.5em; margin-bottom:0.2em; color:#7c39c3;">
          Niveau {{niv}}
          {{#with (lookup ../sortsMemorizedByLevel niv) as |memo|}}
            <span style="font-size:0.95em; color:#888; margin-left:1.2em;">
  ({{memo.count}} / {{memo.max}} mémorisés)
</span>

          {{/with}}
        </h3>
        <table class="sort-table" style="width:100%; margin-bottom:0.8em;">
          <thead>
            <tr>
              <th>Nom</th><th>École</th><th>Portée</th><th>Durée</th>
              <th>Zone Effet</th><th>Jet Sauve</th><th>Composantes</th>
              <th>Incant.</th><th style="width:100px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each (lookup ../sortsParNiveau niv) as |sort|}}
              <tr class="sort-row" data-sort-id="{{sort._id}}">
                <td draggable="true"
                    class="sort-drag sort-cast-img"
                    data-sort-id="{{sort._id}}"
                    data-item-id="{{sort._id}}"
                    data-item-name="{{sort.name}}"
                    style="cursor:pointer; white-space:nowrap;"
                    title="Lancer / Glisser ce sort dans la barre de macro">

                  <!-- + / – -->
                  <i class="fas fa-plus-circle sort-memorize-plus"
                     data-sort-id="{{sort._id}}"
                     title="Ajouter une mémorisation"
                     style="color:#27ae60; margin-right:0.12em; cursor:pointer; font-size:1.08em; vertical-align:middle;"></i>
                  <i class="fas fa-minus-circle sort-memorize-minus"
                     data-sort-id="{{sort._id}}"
                     title="Retirer une mémorisation"
                     style="color:#e74c3c; margin-right:0.2em; cursor:pointer; font-size:1.08em; vertical-align:middle;"></i>
<span class="sort-memorize-badge"
      title="{{#if (getFlag sort 'add2e.memorizedCount')}}
               {{getFlag sort 'add2e.memorizedCount'}}
             {{else}}0{{/if}}
             mémorisé{{#unless (eq (getFlag sort 'add2e.memorizedCount') 1)}}s{{/unless}}">
  {{#if (getFlag sort 'add2e.memorizedCount')}}
    {{getFlag sort 'add2e.memorizedCount'}}
  {{else}}0{{/if}}
</span>

                  <!-- Icône -->
                  {{#if sort.img}}
                    <img src="{{sort.img}}"
                         alt="{{sort.name}}"
                         style="width:24px; height:24px; object-fit:cover; border-radius:4px; box-shadow:0 1px 3px #0002; background:#eaeaff; border:1px solid #bbb; margin-left:0.1em;">
                  {{/if}}

                  <!-- Nom -->
                  <span class="toggle-sort-desc-chat"
                        data-sort-id="{{sort._id}}"
                        style="margin-left:0.35em; font-weight:bold; color:#6a3c99; cursor:pointer;">
                    {{sort.name}}
                  </span>
 
                </td>

                <td>{{sort.system.école}}</td>
                <td>{{formatSortChamp sort.system.portee}}</td>
                <td>{{formatSortChamp sort.system.duree}}</td>
                <td>{{formatSortChamp sort.system.zone_effet}}</td>
                <td>{{sort.system.jet_sauvegarde}}</td>
                <!-- Actions (éditer/supprimer) -->
                <td style="text-align:center;">
                  <i class="fas fa-edit sort-edit"
                     data-sort-id="{{sort._id}}"
                     title="Éditer"
                     style="color:#7b4c9a; margin-right:0.22em; cursor:pointer;"></i>
                  <i class="fas fa-trash sort-delete"
                     data-sort-id="{{sort._id}}"
                     title="Supprimer"
                     style="color:#c0392b; cursor:pointer;"></i>
                </td>
              </tr>
              <tr class="sort-desc-row"
                  id="desc-chat-{{sort._id}}"
                  style="display:none;">
                <td colspan="9"
                    style="background:#f5f1fa; color:#48307a; font-size:0.98em; border-top:1px solid #d6d6ee;">
                  {{{sort.system.description}}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/each}}
  {{else}}
    <p>Aucun sort mémorisé ou connu.</p>
  {{/if}}
</section>

