            <td>{{effet.duration}}</td>
            <td style="text-align:center;">
              <i class="fas fa-edit effect-edit"
                data-effect-id="{{effet.id}}"
                title="Éditer"
                style="color:#6b33a2; cursor:pointer; margin-right:0.4em;"></i>
              <i class="fas fa-trash effect-delete"
                data-effect-id="{{effet.id}}"
                title="Supprimer"
                style="color:#c0392b; cursor:pointer;"></i>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p style="margin-top:1.5em; color:#888;">Aucun effet actif.</p>
  {{/if}}
</section>



<!-- Capacités spéciales de Classe -->
<h3>Classe</h3>
{{#if (length actor.system.details_classe.specialAbilities)}}
  <ul>
    {{#each actor.system.details_classe.specialAbilities as |abil|}}
      {{#if abil.nom}}
        <li><strong>{{abil.nom}}</strong> : {{abil.description}}</li>
      {{else}}
        <li>{{abil}}</li>
      {{/if}}
    {{/each}}
  </ul>
{{else}}
  <p>Aucune capacité spéciale de classe.</p>
{{/if}}

<!-- Capacités raciales -->
<h3>Race</h3>
{{#if (length actor.system.details_race.capacites)}}
  <ul>
    {{#each actor.system.details_race.capacites as |cap|}}
      <li>{{cap}}</li>
    {{/each}}
  </ul>
{{else}}
  <p>Aucune capacité raciale définie.</p>
{{/if}}


