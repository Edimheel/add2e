<form class="sheet actor add2e personnage add2e-character-v3">
  <input type="hidden" class="a2e-active-tab-input" name="flags.add2e.activeSheetTab" value="{{activeTab}}">
  <div class="a2e-shell">
    <header class="a2e-header">
      <div>
        <img class="a2e-portrait" src="{{actor.img}}" alt="Portrait du personnage" data-edit="img">
      </div>

      <div>
        <div class="a2e-name-line">
          <input class="a2e-name" type="text" name="name" value="{{actor.name}}" aria-label="Nom du personnage">

          <div class="a2e-field a2e-player-top">
            <label>Joueur</label>
            <input type="text" name="system.nom_joueur" value="{{actor.system.nom_joueur}}">
          </div>
        </div>

        <div class="a2e-id-grid">
          <div class="a2e-field">
            <label>Classe</label>
            <input type="text" name="system.classe" value="{{actor.system.classe}}">
          </div>

          <div class="a2e-field">
            <label>Race</label>
            <input type="text" name="system.race" value="{{actor.system.race}}">
          </div>

          <div class="a2e-field">
            <label>Niveau</label>
            <input type="number" name="system.niveau" value="{{actor.system.niveau}}" min="1">
          </div>

          <div class="a2e-field a2e-xp-field">
            <label>XP</label>
            <div class="a2e-xp-inline">
              <input type="number" name="system.xp" value="{{actor.system.xp}}" min="0" step="1" title="{{actor.system.progression_xp}}">
              <button type="button" class="a2e-icon-btn" data-add2e-mx="xp" title="Ajouter de l'XP">+</button>
            </div>
          </div>

          <div class="a2e-field">
            <label>Titre</label>
            <input type="text" value="{{progressionCourante.title}}" readonly>
          </div>

          <div class="a2e-field">
            <label>Alignement</label>
            <select name="system.alignement">
              {{#each alignementsDisponibles as |algn|}}
                <option value="{{algn}}" {{#if (eq ../actor.system.alignement algn)}}selected{{/if}}>{{algn}}</option>
              {{/each}}
            </select>
          </div>

          <div class="a2e-field">
            <label>Mouvement</label>
            <input type="text" value="{{#if system.movement}}{{system.movement}}{{else}}{{actor.system.movement}}{{/if}} m" readonly>
          </div>

          <div class="a2e-field">
            <label>PV max</label>
            <input type="text" value="{{actor.system.points_de_coup}}" readonly>
          </div>

          <div class="a2e-field">
            <label>PV courant</label>
            <input type="number" name="system.pdv" value="{{actor.system.pdv}}" class="pv-courant">
          </div>

          <div class="a2e-field">
            <label>CA</label>
            <input type="text" value="{{actor.system.ca_total}}" readonly>
          </div>

          <div class="a2e-field">
            <label>THAC0</label>
            <input type="text" value="{{combatDefense.thaco}}" readonly>
          </div>

        </div>
      </div>
    </header>

    <div class="a2e-character-saves-layout">
      <section class="a2e-panel a2e-characteristics-always">
      <h2>
        Caractéristiques
        <i class="fas fa-dice roll-caracs-btn" style="margin-left:0.35em;color:#8e44ad;cursor:pointer;" title="Tirer les caractéristiques"></i>
      </h2>

      <div class="a2e-panel-body">
        <table class="a2e-carac-table a2e-carac-table-clean">
          <tbody>
            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="force" title="Jet de Force" style="color:#27ce46;"></i>
                  <span class="carac-short">FOR</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="force" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="force"
                       title="Base : {{actor.system.force_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.force}}&#10;Total : {{add actor.system.force_base actor.system.bonus_caracteristiques.force}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.force_base actor.system.bonus_caracteristiques.force}}</span>
                    {{#if actor.system.bonus_caracteristiques.force}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.force 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.force}})</span>
                    {{/if}}
                  </div>
                  {{#if canExceptionalStrength}}
                    {{#if editable}}
                      <input type="number" name="system.force_ex" value="{{actor.system.force_ex}}" min="0" max="100" step="1" class="carac-ex-square" title="Force exceptionnelle (18/xx)" placeholder="xx">
                    {{else}}
                      <div class="carac-ex-square carac-ex-square--readonly" title="Force exceptionnelle (18/xx)">{{actor.system.force_ex}}</div>
                    {{/if}}
                  {{/if}}
                  <button type="button" class="carac-btn plus" data-carac="force" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Toucher</label><input type="text" name="system.force_bonus_toucher" value="{{actor.system.force_bonus_toucher}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Dégâts</label><input type="text" name="system.force_bonus_degats" value="{{actor.system.force_bonus_degats}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Poids</label><input type="text" name="system.force_poids" value="{{actor.system.force_poids}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Portes</label><input type="text" name="system.force_ouvrir" value="{{actor.system.force_ouvrir}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Barreaux</label><input type="text" name="system.force_tordre" value="{{actor.system.force_tordre}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="dexterite" title="Jet de Dextérité" style="color:#ffae2f;"></i>
                  <span class="carac-short">DEX</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="dexterite" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="dexterite"
                       title="Base : {{actor.system.dexterite_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.dexterite}}&#10;Total : {{add actor.system.dexterite_base actor.system.bonus_caracteristiques.dexterite}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.dexterite_base actor.system.bonus_caracteristiques.dexterite}}</span>
                    {{#if actor.system.bonus_caracteristiques.dexterite}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.dexterite 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.dexterite}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="dexterite" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Réaction</label><input type="text" name="system.dex_att" value="{{actor.system.dex_att}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>CA défense</label><input type="text" name="system.dex_def" value="{{actor.system.dex_def}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="constitution" title="Jet de Constitution" style="color:#e74c3c;"></i>
                  <span class="carac-short">CON</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="constitution" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="constitution"
                       title="Base : {{actor.system.constitution_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.constitution}}&#10;Total : {{add actor.system.constitution_base actor.system.bonus_caracteristiques.constitution}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.constitution_base actor.system.bonus_caracteristiques.constitution}}</span>
                    {{#if actor.system.bonus_caracteristiques.constitution}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.constitution 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.constitution}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="constitution" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>PV / niv.</label><input type="text" name="system.con_pv" value="{{actor.system.con_pv}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Choc</label><input type="text" name="system.con_trauma" value="{{actor.system.con_trauma}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Résurrection</label><input type="text" name="system.con_resu" value="{{actor.system.con_resu}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="intelligence" title="Jet d’Intelligence" style="color:#2980b9;"></i>
                  <span class="carac-short">INT</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="intelligence" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="intelligence"
                       title="Base : {{actor.system.intelligence_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.intelligence}}&#10;Total : {{add actor.system.intelligence_base actor.system.bonus_caracteristiques.intelligence}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.intelligence_base actor.system.bonus_caracteristiques.intelligence}}</span>
                    {{#if actor.system.bonus_caracteristiques.intelligence}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.intelligence 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.intelligence}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="intelligence" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Langues</label><input type="text" name="system.int_langues" value="{{actor.system.int_langues}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>% sort</label><input type="text" name="system.int_chance_sort" value="{{actor.system.int_chance_sort}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts min</label><input type="text" name="system.int_sort_min" value="{{actor.system.int_sort_min}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts max</label><input type="text" name="system.int_sort_max" value="{{actor.system.int_sort_max}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>/ niveau</label><input type="text" name="system.int_sort_par_niveau" value="{{actor.system.int_sort_par_niveau}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="sagesse" title="Jet de Sagesse" style="color:#9b59b6;"></i>
                  <span class="carac-short">SAG</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="sagesse" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="sagesse"
                       title="Base : {{actor.system.sagesse_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.sagesse}}&#10;Total : {{add actor.system.sagesse_base actor.system.bonus_caracteristiques.sagesse}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.sagesse_base actor.system.bonus_caracteristiques.sagesse}}</span>
                    {{#if actor.system.bonus_caracteristiques.sagesse}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.sagesse 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.sagesse}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="sagesse" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Bonus magie</label><input type="text" name="system.sag_bm_magie" value="{{actor.system.sag_bm_magie}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Sorts bonus</label><input type="text" name="system.sag_sort_suppl" value="{{actor.system.sag_sort_suppl}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>% échec</label><input type="text" name="system.sag_echec" value="{{actor.system.sag_echec}}" readonly></div>
                </div>
              </td>
            </tr>

            <tr>
              <td class="carac-label-td">
                <div class="carac-flex">
                  <i class="fas fa-dice-d20 roll-stat" data-stat="charisme" title="Jet de Charisme" style="color:#e056fd;"></i>
                  <span class="carac-short">CHA</span>
                </div>
              </td>
              <td>
                <div class="carac-control-group">
                  <button type="button" class="carac-btn moins" data-carac="charisme" tabindex="-1">−</button>
                  <div class="carac-value carac-drop-target" data-carac="charisme"
                       title="Base : {{actor.system.charisme_base}}&#10;Bonus racial : {{actor.system.bonus_caracteristiques.charisme}}&#10;Total : {{add actor.system.charisme_base actor.system.bonus_caracteristiques.charisme}}">
                    <span style="font-size:1.45em;font-weight:700;line-height:1;">{{add actor.system.charisme_base actor.system.bonus_caracteristiques.charisme}}</span>
                    {{#if actor.system.bonus_caracteristiques.charisme}}
                      <span class="carac-racial-bonus-inline">(race {{#if (gt actor.system.bonus_caracteristiques.charisme 0)}}+{{/if}}{{actor.system.bonus_caracteristiques.charisme}})</span>
                    {{/if}}
                  </div>
                  <button type="button" class="carac-btn plus" data-carac="charisme" tabindex="-1">+</button>
                </div>
              </td>
              <td>
                <div class="carac-adjustments-line">
                  <div class="a2e-adjustment-item"><label>Compagnons</label><input type="text" name="system.cha_compagnons" value="{{actor.system.cha_compagnons}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Loyauté</label><input type="text" name="system.cha_loy" value="{{actor.system.cha_loy}}" readonly></div>
                  <div class="a2e-adjustment-item"><label>Réaction</label><input type="text" name="system.cha_react" value="{{actor.system.cha_react}}" readonly></div>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

      <aside class="a2e-saves-square-strip a2e-saves-square-side" aria-label="Jets de sauvegarde">
        <div class="a2e-saves-square-title">
          <i class="fas fa-dice-d20"></i>
          <span>Sauv.</span>
        </div>
      <div class="a2e-save-square-grid">
        {{#each saveShortLabels as |saveLabel idx|}}
          <div class="a2e-save-square a2e-save-square-{{idx}}">
            {{#if (eq idx 0)}}<i class="fas fa-skull-crossbones roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 1)}}<i class="fas fa-gem roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 2)}}<i class="fas fa-magic roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 3)}}<i class="fas fa-fire roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            {{#if (eq idx 4)}}<i class="fas fa-scroll roll-save" data-save="{{idx}}" title="{{lookup ../saveTitles idx}}"></i>{{/if}}
            <div class="a2e-save-square-label">
              {{#if (eq idx 0)}}Paralysie / poison / mort magique{{/if}}
              {{#if (eq idx 1)}}Pétrification / polymorphose{{/if}}
              {{#if (eq idx 2)}}Baguettes et badines{{/if}}
              {{#if (eq idx 3)}}Souffles{{/if}}
              {{#if (eq idx 4)}}Sortilèges{{/if}}
            </div>
            <div class="a2e-save-square-value">
              {{#if ../progressionCourante}}
                {{lookup ../progressionCourante.savingThrows idx}}
              {{else}}
                —
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
      </aside>
    </div>

    <nav class="a2e-tabs sheet-tabs tabs" data-group="primary">
      <a class='item {{#if (eq activeTab "resume")}}active{{/if}}' data-tab="resume" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-id-card"></i> Résumé</a>
      <a class='item {{#if (eq activeTab "combat")}}active{{/if}}' data-tab="combat" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-shield-alt"></i> Combat</a>
      <a class='item {{#if (eq activeTab "capacites")}}active{{/if}}' data-tab="capacites" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-bolt"></i> Capacités</a>
      <a class='item {{#if (eq activeTab "sorts")}}active{{/if}}' data-tab="sorts" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-magic"></i> Sorts</a>
      <a class='item {{#if (eq activeTab "effets")}}active{{/if}}' data-tab="effets" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-sparkles"></i> Effets</a>
      <a class='item {{#if (eq activeTab "equipement")}}active{{/if}}' data-tab="equipement" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-suitcase"></i> Équipement</a>
      <a class='item {{#if (eq activeTab "notes")}}active{{/if}}' data-tab="notes" data-group="primary" onclick="event.preventDefault();const r=this.closest('.add2e-character-v3');const t=this.dataset.tab;const h=r.querySelector('.a2e-active-tab-input');if(h)h.value=t;r.querySelectorAll('.a2e-tabs .item[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));r.querySelectorAll('.sheet-body .a2e-tab-content[data-tab]').forEach(e=>e.classList.toggle('active',e.dataset.tab===t));"><i class="fas fa-feather-alt"></i> Notes</a>
    </nav>

    <main class="sheet-body">
      <section class='a2e-tab-content tab tab-resume {{#if (eq activeTab "resume")}}active{{/if}}' data-group="primary" data-tab="resume">
        <div class="a2e-summary-dashboard">
          <div>
            <div class="a2e-summary-metrics">
              <div class="a2e-summary-card">
                <i class="fas fa-shield-alt"></i>
                <div>
                  <label>CA</label>
                  <strong>{{combatDefense.ac_totale}}</strong>
                  <small>physique {{combatDefense.ac_naturelle}}</small>
                </div>
              </div>

              <div class="a2e-summary-card">
                <i class="fas fa-crosshairs"></i>
                <div>
                  <label>THAC0</label>
                  <strong>{{combatDefense.thaco}}</strong>
                  <small>attaque de base</small>
                </div>
              </div>

              <div class="a2e-summary-card">
                <i class="fas fa-running"></i>
                <div>
                  <label> Mouvement</label>
... enormous