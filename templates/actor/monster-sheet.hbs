<form class="add2e sheet monster-sheet add2e-monster-readable-sheet" autocomplete="off">
  <style>
    .window-app .window-content:has(.add2e-monster-readable-sheet),.application .window-content:has(.add2e-monster-readable-sheet){overflow:hidden!important;padding:0!important;}.add2e-monster-readable-sheet{--gold:#d9bf73;--dark:#4a3b2a;--red:#7a2828;--panel:rgba(255,252,239,.96);--soft:rgba(255,248,224,.92);color:#2f210d;background:linear-gradient(135deg,#f7eed3 0%,#efe0b8 100%);min-width:860px;height:100%;min-height:0;display:flex;flex-direction:column;overflow:hidden}.add2e-monster-readable-sheet *{box-sizing:border-box}.monster-header{display:grid;grid-template-columns:130px 1fr;gap:14px;align-items:start;padding:10px;background:rgba(255,248,220,.72);border-bottom:1px solid var(--gold);flex:0 0 auto}.profile-img img{width:120px;height:120px;object-fit:cover;border-radius:8px;border:1px solid #6e5c2b;background:#222;box-shadow:0 3px 5px rgba(0,0,0,.28);cursor:pointer}.header-info h1{margin:0 0 8px}.header-info h1 input{width:100%;font-size:2rem;font-weight:900;color:#1d1606;border:1px solid var(--gold);border-radius:6px;background:rgba(255,252,239,.94);padding:4px 8px}.meta-grid,.key-stats,.combat-grid,.monster-info-grid{display:grid;grid-template-columns:repeat(6,minmax(90px,1fr));gap:8px}.key-stats{margin-top:8px}.meta-box,.key-stat,.form-group,.monster-info{background:var(--panel);border:1px solid var(--gold);border-radius:8px;padding:7px;min-height:50px}.meta-box label,.key-stat label,.form-group label,.monster-info b{display:block;font-weight:900;color:#6f4b12;margin-bottom:3px;font-size:.78rem;text-transform:uppercase;letter-spacing:.02em}.add2e-monster-readable-sheet input,.add2e-monster-readable-sheet textarea{width:100%;background:#fffaf0;border:1px solid #b9a15d;border-radius:4px;padding:4px 6px;color:#1d1606}.key-stat input{text-align:center;font-weight:900;font-size:1.05rem}.saves-section{display:flex;align-items:center;justify-content:center;gap:8px;padding:8px 10px;background:rgba(250,242,216,.88);border-bottom:1px solid var(--gold);min-height:64px;flex:0 0 auto}.save-btn{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;width:76px;min-height:50px;border-radius:7px;border:1px solid rgba(0,0,0,.2);color:#fff;font-size:.78rem;cursor:pointer;text-shadow:0 1px 2px #000;box-shadow:0 2px 4px rgba(0,0,0,.2)}.save-btn:hover{transform:translateY(-1px)}.save-btn .val{font-size:1.25rem;font-weight:900}.sv-paralysie{background:#16a085}.sv-baguette{background:#f39c12}.sv-petrif{background:#8e44ad}.sv-souffle{background:#d35400}.sv-sorts{background:#c0392b}.sheet-tabs{display:flex;flex-wrap:nowrap;gap:3px;padding:8px 10px 0;background:rgba(250,242,216,.85);border-bottom:1px solid var(--gold);overflow-x:auto;margin:0;flex:0 0 auto}.sheet-tabs .item{display:inline-flex;align-items:center;justify-content:center;gap:5px;padding:7px 12px;border:1px solid var(--gold);border-bottom:0;border-radius:7px 7px 0 0;background:#fffdf4;color:#6f4b12;font-weight:900;text-decoration:none;cursor:pointer;white-space:nowrap}.sheet-tabs .item.active{background:linear-gradient(180deg,#9a3a2f,#6f201a);color:#fff;border-color:#6f201a}.sheet-body{padding:12px;flex:1 1 auto;min-height:0;height:auto!important;overflow-y:auto;overflow-x:hidden}.tab:not(.active){display:none!important}.tab.active{display:block}.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;align-items:start}.panel{background:var(--panel);border:1px solid var(--gold);border-radius:9px;overflow:hidden;margin-bottom:12px}.panel>h2,.panel>h3{margin:0;padding:8px 10px;background:rgba(240,224,169,.68);border-bottom:1px solid var(--gold);color:#6f4b12;font-size:1.02rem;font-weight:900}.panel-body{padding:10px}.combat-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.monster-info-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.monster-info{background:#fffdf4}.cap-card{border:1px solid #dcc782;border-radius:8px;background:#fffdf4;padding:9px;margin-bottom:8px}.cap-card.system{border-color:#ca8a8a;background:#fff7f2}.cap-head{display:flex;justify-content:space-between;gap:8px;align-items:center;margin-bottom:5px}.cap-name{font-weight:900;color:#3d2b0a}.cap-type{font-size:.78rem;color:#6f4b12;font-weight:900;border:1px solid #d6bd70;background:#fff8df;border-radius:999px;padding:2px 7px;white-space:nowrap}.cap-card.system .cap-type{border-color:#ca8a8a;background:#fff0ec;color:#8a1f18}.badge-list{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px}.badge{display:inline-flex;align-items:center;padding:3px 6px;border-radius:999px;border:1px solid #d6bd70;background:#fff8df;color:#55390d;font-weight:700;font-size:.78rem}.badge.bad{border-color:#ca8a8a;background:#fff0ec;color:#8a1f18}.add2e-table{width:100%;border-collapse:collapse;background:#fffdf6;font-size:.92rem}.add2e-table th,.add2e-table td{border:1px solid #dac276;padding:5px 6px;vertical-align:middle;color:#2f250c}.add2e-table th{background:#ead99d;color:#55390d;font-weight:900;text-align:left}.add2e-table tr:hover{background:rgba(0,0,0,.035)}.action-icons a{margin-left:6px;color:#5d4b24;cursor:pointer}.action-icons a:hover{color:#000}.item-name-img{display:flex;align-items:center;gap:8px;font-weight:800;color:#2c1b12}.item-name-img img{border-radius:4px;border:1px solid #999}.spell-level-header{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(90deg,#6a3c99 0%,#a68ac2 100%);color:#fff;padding:6px 10px;margin-top:12px;border-radius:4px 4px 0 0;font-weight:900}.muted{color:#7f704d;font-style:italic}.description-box{width:100%;min-height:220px;border:1px solid #dcc782;border-radius:8px;background:rgba(255,255,255,.45);padding:10px;resize:vertical}
  </style>

  <header class="monster-header">
    <div class="profile-img"><img src="{{img}}" data-edit="img" title="{{actor.name}}"/></div>
    <div class="header-info">
      <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Nom du monstre"/></h1>
      <div class="meta-grid">
        <div class="meta-box"><label>Type</label><input type="text" name="system.type" value="{{system.type}}"/></div>
        <div class="meta-box"><label>Sous-type</label><input type="text" name="system.type_monstre" value="{{system.type_monstre}}"/></div>
        <div class="meta-box"><label>Taille</label><input type="text" name="system.size" value="{{system.size}}"/></div>
        <div class="meta-box"><label>Alignement</label><input type="text" name="system.alignment" value="{{system.alignment}}"/></div>
        <div class="meta-box"><label>Fréquence</label><input type="text" name="system.frequency" value="{{system.frequency}}"/></div>
        <div class="meta-box"><label>PX</label><input type="number" name="system.xp" value="{{system.xp}}"/></div>
      </div>
      <div class="key-stats">
        <div class="key-stat"><label>CA</label><input type="number" name="system.armorClass" value="{{system.armorClass}}"/></div>
        <div class="key-stat"><label>CA totale</label><input type="number" name="system.ca_total" value="{{system.ca_total}}"/></div>
        <div class="key-stat"><label>TAC0</label><input type="number" name="system.thac0" value="{{system.thac0}}"/></div>
        <div class="key-stat"><label>PV</label><input type="number" name="system.pdv" value="{{system.pdv}}"/></div>
        <div class="key-stat"><label>DV</label><input type="text" name="system.hitDice" value="{{system.hitDice}}"/></div>
        <div class="key-stat"><label>Mouvement</label><input type="text" name="system.movement" value="{{system.movement}}"/></div>
      </div>
    </div>
  </header>

  <section class="saves-section">
    {{#if isSavingThrowString}}
      <div style="flex:1;text-align:center"><label style="font-weight:bold;margin-right:10px">Sauvegardes comme :</label><input type="text" name="system.savingThrows" value="{{system.savingThrows}}" style="width:50%;font-weight:bold"/></div>
    {{else}}
      <a class="save-btn sv-paralysie roll-save" data-save-index="0" data-save-val="{{calculatedSaves.paralysie}}" title="Paralysie / Poison / Mort"><i class="fas fa-skull"></i><span class="val">{{calculatedSaves.paralysie}}</span></a>
      <a class="save-btn sv-baguette roll-save" data-save-index="1" data-save-val="{{calculatedSaves.baguettes}}" title="Baguettes / Bâtons"><i class="fas fa-magic"></i><span class="val">{{calculatedSaves.baguettes}}</span></a>
      <a class="save-btn sv-petrif roll-save" data-save-index="2" data-save-val="{{calculatedSaves.petrification}}" title="Pétrification / Polymorphose"><i class="fas fa-mountain"></i><span class="val">{{calculatedSaves.petrification}}</span></a>
      <a class="save-btn sv-souffle roll-save" data-save-index="3" data-save-val="{{calculatedSaves.souffle}}" title="Souffles"><i class="fas fa-wind"></i><span class="val">{{calculatedSaves.souffle}}</span></a>
      <a class="save-btn sv-sorts roll-save" data-save-index="4" data-save-val="{{calculatedSaves.sorts}}" title="Sorts"><i class="fas fa-scroll"></i><span class="val">{{calculatedSaves.sorts}}</span></a>
    {{/if}}
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="combat"><i class="fas fa-fist-raised"></i> Combat</a>
    <a class="item" data-tab="capacites"><i class="fas fa-list-check"></i> Capacités</a>
    <a class="item" data-tab="magie"><i class="fas fa-magic"></i> Magie</a>
    <a class="item" data-tab="description"><i class="fas fa-book-open"></i> Détails</a>
    <a class="item" data-tab="effets"><i class="fas fa-bolt"></i> Effets système</a>
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-group="primary" data-tab="combat">
      <div class="two-col">
        <section class="panel"><h2>Combat</h2><div class="panel-body combat-grid">
          <div class="form-group"><label>Nb attaques</label><input type="text" name="system.attacksCount" value="{{system.attacksCount}}"/></div>
          <div class="form-group"><label>Dégâts</label><input type="text" name="system.damage" value="{{system.damage}}"/></div>
          <div class="form-group"><label>Type d’attaque</label><input type="text" name="system.attackTypes" value="{{system.attackTypes}}"/></div>
          <div class="form-group"><label>Initiative</label><input type="number" name="system.initiative" value="{{system.initiative}}"/></div>
          <div class="form-group"><label>Attaques spéciales</label><input type="text" name="system.specialAttacks" value="{{system.specialAttacks}}"/></div>
          <div class="form-group"><label>Défenses spéciales</label><input type="text" name="system.specialDefenses" value="{{system.specialDefenses}}"/></div>
          <div class="form-group"><label>Résistance magique</label><input type="text" name="system.magicResistance" value="{{system.magicResistance}}"/></div>
          <div class="form-group"><label>Moral</label><input type="number" name="system.morale" value="{{system.morale}}"/></div>
        </div></section>
        <section class="panel"><h2>Rencontre</h2><div class="panel-body monster-info-grid">
          <div class="monster-info"><b>Habitat</b><span>{{system.habitat}}</span></div>
          <div class="monster-info"><b>Organisation</b><span>{{system.organization}}</span></div>
          <div class="monster-info"><b>Cycle</b><span>{{system.activityCycle}}</span></div>
          <div class="monster-info"><b>Régime</b><span>{{system.diet}}</span></div>
          <div class="monster-info"><b>Nombre</b><span>{{system.numberAppearing}}</span></div>
          <div class="monster-info"><b>Trésor</b><span>{{system.treasure}}</span></div>
        </div></section>
      </div>

      <section class="panel"><h2>Armes & attaques jouables</h2><div class="panel-body"><table class="add2e-table">
        <thead><tr><th>Attaque</th><th>Dégâts</th><th>Portée</th><th>Équipée</th><th></th></tr></thead><tbody>
        {{#each listeArmes as |arme|}}
        <tr><td><div class="item-name-img arme-img-attack" data-item-id="{{arme._id}}" style="cursor:pointer"><img src="{{arme.img}}" width="28" height="28"/>{{arme.name}}</div></td><td>{{#with (lookup arme.system "dégâts") as |deg|}}{{#if deg}}{{deg.contre_moyen}} / {{deg.contre_grand}}{{else}}—{{/if}}{{/with}}</td><td>{{arme.system.portee_courte}} / {{arme.system.portee_moyenne}} / {{arme.system.portee_longue}}</td><td style="text-align:center"><a class="item-equip" data-item-id="{{arme._id}}"><i class="fas fa-shield-alt" style="{{#if arme.system.equipee}}color:#27ae60;{{else}}color:#bbb;{{/if}}"></i></a></td><td class="action-icons" style="text-align:right"><a class="arme-edit" data-item-id="{{arme._id}}"><i class="fas fa-edit"></i></a><a class="arme-delete" data-item-id="{{arme._id}}"><i class="fas fa-trash"></i></a></td></tr>
        {{/each}}
        </tbody></table></div></section>

      <div class="two-col">
        <section class="panel"><h2>Armure & protection</h2><div class="panel-body"><table class="add2e-table"><thead><tr><th>Protection</th><th>CA</th><th>Équipée</th><th></th></tr></thead><tbody>{{#each listeArmures as |item|}}<tr><td><div class="item-name-img"><img src="{{item.img}}" width="28" height="28"/>{{item.name}}</div></td><td>{{item.system.ac}}</td><td style="text-align:center"><a class="item-equip" data-item-id="{{item._id}}"><i class="fas fa-tshirt" style="{{#if item.system.equipee}}color:#27ae60;{{else}}color:#bbb;{{/if}}"></i></a></td><td class="action-icons" style="text-align:right"><a class="armure-edit" data-item-id="{{item._id}}"><i class="fas fa-edit"></i></a><a class="armure-delete" data-item-id="{{item._id}}"><i class="fas fa-trash"></i></a></td></tr>{{/each}}</tbody></table></div></section>
        <section class="panel"><h2>Inventaire / trésor</h2><div class="panel-body"><table class="add2e-table"><thead><tr><th>Objet</th><th>Équipé</th><th></th></tr></thead><tbody>{{#each listeObjets as |item|}}<tr><td><div class="item-name-img"><img src="{{item.img}}" width="28" height="28"/>{{item.name}}</div></td><td style="text-align:center"><a class="item-equip" data-item-id="{{item._id}}"><i class="fas fa-circle" style="{{#if item.system.equipee}}color:#27ae60;{{else}}color:#bbb;{{/if}}"></i></a></td><td class="action-icons" style="text-align:right"><a class="objet-edit" data-item-id="{{item._id}}"><i class="fas fa-edit"></i></a><a class="objet-delete" data-item-id="{{item._id}}"><i class="fas fa-trash"></i></a></td></tr>{{/each}}</tbody></table></div></section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="capacites">
      <div class="two-col">
        <section class="panel"><h2>Capacités / notes MJ</h2><div class="panel-body">
          {{#each system.capacites_mj as |cap|}}
            <div class="cap-card"><div class="cap-head"><span class="cap-name">{{cap.name}}</span><span class="cap-type">{{cap.type}}</span></div><div>{{cap.description}}</div>{{#if cap.tags}}<div class="badge-list">{{#each cap.tags as |tag|}}<span class="badge">{{tag}}</span>{{/each}}</div>{{/if}}</div>
          {{else}}
            {{#each system.capacites_monstre as |cap|}}
              <div class="cap-card"><div class="cap-head"><span class="cap-name">{{cap.name}}</span><span class="cap-type">{{cap.type}}</span></div><div>{{cap.description}}</div>{{#if cap.tags}}<div class="badge-list">{{#each cap.tags as |tag|}}<span class="badge">{{tag}}</span>{{/each}}</div>{{/if}}</div>
            {{else}}<p class="muted">Aucune capacité informative renseignée.</p>{{/each}}
          {{/each}}
        </div></section>
        <section class="panel"><h2>Effets système prévus</h2><div class="panel-body">
          {{#each system.capacites_systeme as |cap|}}
            <div class="cap-card system"><div class="cap-head"><span class="cap-name">{{cap.name}}</span><span class="cap-type">Effet système</span></div><div>{{cap.description}}</div>{{#if cap.activation}}<p><b>Activation :</b> {{cap.activation}}</p>{{/if}}{{#if cap.effet_systeme}}<p><b>Règle appliquée :</b> {{cap.effet_systeme}}</p>{{/if}}{{#if cap.tags}}<div class="badge-list">{{#each cap.tags as |tag|}}<span class="badge bad">{{tag}}</span>{{/each}}</div>{{/if}}</div>
          {{else}}<p class="muted">Aucun effet système propre au monstre. Les tactiques et informations restent dans Capacités / notes MJ si elles ne sont pas quantifiables.</p>{{/each}}
        </div></section>
      </div>
      <section class="panel"><h2>Sens, langues et tags techniques</h2><div class="panel-body">
        <div class="monster-info-grid"><div class="monster-info"><b>Sens</b><input type="text" name="system.senses" value="{{system.senses}}"/></div><div class="monster-info"><b>Langues</b><input type="text" name="system.languages" value="{{system.languages}}"/></div></div>
        {{#if system.tags}}<h3>Tags</h3><div class="badge-list">{{#each system.tags as |tag|}}<span class="badge">{{tag}}</span>{{/each}}</div>{{/if}}
        {{#if system.effectTags}}<h3>Effect tags</h3><div class="badge-list">{{#each system.effectTags as |tag|}}<span class="badge">{{tag}}</span>{{/each}}</div>{{/if}}
      </div></section>
    </div>

    <div class="tab" data-group="primary" data-tab="magie">
      {{#if niveauxSorts.length}}
        {{#each niveauxSorts as |niv|}}
          <div class="spell-level-header"><span>Niveau {{niv}}</span>{{#with (lookup ../sortsMemorizedByLevel niv) as |memo|}}<span style="font-size:.82rem;opacity:.9">Mémorisé : {{memo.count}}</span>{{/with}}</div>
          <table class="add2e-table"><thead><tr><th>Sort / pouvoir</th><th>Portée</th><th>Durée</th><th>Incant.</th><th>Slots</th><th></th></tr></thead><tbody>{{#each (lookup ../sortsParNiveau niv) as |sort|}}<tr><td><div class="item-name-img"><img src="{{sort.img}}" class="sort-cast-img" data-sort-id="{{sort._id}}" width="24" height="24" style="cursor:pointer"/><span class="toggle-sort-desc-chat" data-sort-id="{{sort._id}}" style="cursor:pointer;color:#4a2372">{{sort.name}}</span></div></td><td>{{formatSortChamp sort.system.portee}}</td><td>{{formatSortChamp sort.system.duree}}</td><td>{{formatSortChamp sort.system.temps_incantation}}</td><td style="text-align:center;font-weight:900;color:purple"><a class="sort-memorize-minus" data-sort-id="{{sort._id}}"><i class="fas fa-minus-circle" style="color:#c0392b"></i></a> {{getFlag sort 'add2e.memorizedCount'}} <a class="sort-memorize-plus" data-sort-id="{{sort._id}}"><i class="fas fa-plus-circle" style="color:#27ae60"></i></a></td><td class="action-icons" style="text-align:right"><a class="sort-edit" data-item-id="{{sort._id}}"><i class="fas fa-edit"></i></a><a class="sort-delete" data-item-id="{{sort._id}}"><i class="fas fa-trash"></i></a></td></tr><tr id="desc-chat-{{sort._id}}" style="display:none"><td colspan="6" style="padding:10px;font-style:italic;color:#555">{{{sort.system.description}}}</td></tr>{{/each}}</tbody></table>
        {{/each}}
      {{else}}<section class="panel"><h2>Magie</h2><div class="panel-body"><p class="muted">Ce monstre ne connaît aucun sort ou pouvoir magique activable.</p></div></section>{{/if}}
    </div>

    <div class="tab" data-group="primary" data-tab="description">
      <section class="panel"><h2>Résumé complet du monstre</h2><div class="panel-body monster-info-grid">
        <div class="monster-info"><b>Fréquence</b><span>{{system.frequency}}</span></div><div class="monster-info"><b>Habitat</b><span>{{system.habitat}}</span></div><div class="monster-info"><b>Organisation</b><span>{{system.organization}}</span></div><div class="monster-info"><b>Cycle</b><span>{{system.activityCycle}}</span></div><div class="monster-info"><b>Régime</b><span>{{system.diet}}</span></div><div class="monster-info"><b>Nombre</b><span>{{system.numberAppearing}}</span></div><div class="monster-info"><b>Intelligence</b><span>{{system.intelligence}}</span></div><div class="monster-info"><b>Moral</b><span>{{system.morale}}</span></div><div class="monster-info"><b>Trésor</b><span>{{system.treasure}}</span></div><div class="monster-info"><b>PX</b><span>{{system.xp}}</span></div><div class="monster-info"><b>Sauvegardes</b><span>{{system.savingThrows}}</span></div><div class="monster-info"><b>RM</b><span>{{system.magicResistance}}</span></div>
      </div></section>
      <section class="panel"><h2>Description complète</h2><div class="panel-body"><textarea name="system.description" class="description-box">{{system.description}}</textarea></div></section>
      <section class="panel"><h2>Notes MJ</h2><div class="panel-body"><textarea name="system.notes" class="description-box" style="min-height:110px">{{system.notes}}</textarea></div></section>
    </div>

    <div class="tab" data-group="primary" data-tab="effets">
      <section class="panel"><h2>Effets système / temporaires</h2><div class="panel-body">
        <p class="muted">Cet onglet ne doit contenir que les effets qui modifient réellement la résolution de jeu ou qui doivent être activés/désactivés. Embuscade et attaque en groupe restent dans Capacités / notes MJ si elles ne sont pas quantifiables.</p>
        <div style="display:flex;justify-content:flex-end;margin-bottom:8px"><a class="effect-control" data-action="create" style="background:#27ae60;color:#fff;padding:5px 10px;border-radius:4px;font-weight:900"><i class="fas fa-plus"></i> Ajouter</a></div>
        <table class="add2e-table"><thead><tr><th>Effet</th><th>Durée</th><th>Description / tags</th><th>Actif</th><th></th></tr></thead><tbody>{{#each activeEffectsList as |eff|}}<tr style="{{#if eff.disabled}}opacity:.58;background:#eee;{{else}}background:rgba(46,204,113,.12);{{/if}}"><td><img src="{{eff.img}}" width="24" height="24" style="vertical-align:middle"/> <b>{{eff.name}}</b></td><td>{{eff.duration}}</td><td><small>{{eff.description}}</small></td><td style="text-align:center"><a class="effect-control" data-action="toggle" data-effect-id="{{eff.id}}"><i class="fas {{#if eff.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i></a></td><td class="action-icons" style="text-align:right"><a class="effect-control" data-action="edit" data-effect-id="{{eff.id}}"><i class="fas fa-edit"></i></a><a class="effect-control" data-action="delete" data-effect-id="{{eff.id}}" style="color:red"><i class="fas fa-trash"></i></a></td></tr>{{else}}<tr><td colspan="5" class="muted">Aucun effet système actif ou préparé.</td></tr>{{/each}}</tbody></table>
      </div></section>
    </div>
  </section>
</form>