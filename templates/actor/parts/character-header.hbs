    <header class="a2e-header">
      <div>
        <img class="a2e-portrait" src="{{actor.img}}" alt="Portrait du personnage" data-edit="img">
      </div>

      <div>
        <div class="a2e-name-line">
          <input class="a2e-name" type="text" name="name" value="{{actor.name}}" aria-label="Nom du personnage">

          <div class="a2e-field a2e-player-top">
            <label>Joueur</label>
            <input type="text" name="system.nom_joueur" value="{{actor.system.nom_joueur}}">
          </div>
        </div>

        <div class="a2e-id-grid">
          {{#if actor.system.multiclasse.enabled}}
            <div class="a2e-field a2e-multiclass-field">
              <label>Classe</label>
              <input type="text" name="system.classe" value="{{actor.system.classe}}" readonly title="{{actor.system.classe}}">
            </div>
          {{else}}
            <div class="a2e-field">
              <label>Classe</label>
              <input type="text" name="system.classe" value="{{actor.system.classe}}">
            </div>
          {{/if}}

          <div class="a2e-field">
            <label>Race</label>
            <input type="text" name="system.race" value="{{actor.system.race}}">
          </div>

          {{#if actor.system.multiclasse.enabled}}
            <div class="a2e-field a2e-multiclass-field">
              <label>Niveau</label>
              <div class="a2e-multiclass-rows" style="display:grid;gap:3px;">
                {{#each actor.system.multiclasse.classes as |cls|}}
                  <div class="a2e-multiclass-row" style="display:grid;grid-template-columns:minmax(54px,.9fr) minmax(44px,1fr);gap:4px;align-items:center;">
                    <span title="{{cls.name}}" style="font-size:.78em;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{cls.name}}</span>
                    <input type="number"
                           name="system.multiclasse.classes.{{@index}}.level"
                           value="{{cls.level}}"
                           data-class-id="{{cls.itemId}}"
                           min="1"
                           step="1"
                           title="{{cls.name}} — niveau">
                  </div>
                {{/each}}
              </div>
            </div>
          {{else}}
            <div class="a2e-field">
              <label>Niveau</label>
              <input type="number" name="system.niveau" value="{{actor.system.niveau}}" min="1">
            </div>
          {{/if}}

          {{#if actor.system.multiclasse.enabled}}
            <div class="a2e-field a2e-xp-field a2e-multiclass-field">
              <label>XP</label>
              <div class="a2e-multiclass-rows" style="display:grid;gap:3px;">
                {{#each actor.system.multiclasse.classes as |cls|}}
                  <div class="a2e-multiclass-row" style="display:grid;grid-template-columns:minmax(54px,.9fr) minmax(70px,1fr);gap:4px;align-items:center;">
                    <span title="{{cls.name}}" style="font-size:.78em;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{cls.name}}</span>
                    <input type="number"
                           name="system.multiclasse.classes.{{@index}}.xp"
                           value="{{cls.xp}}"
                           data-class-id="{{cls.itemId}}"
                           min="0"
                           step="1"
                           title="{{cls.name}} — XP / prochain seuil : {{cls.nextXp}}">
                  </div>
                {{/each}}
              </div>
            </div>
          {{else}}
            <div class="a2e-field a2e-xp-field">
              <label>XP</label>
              <div class="a2e-xp-inline">
                <input type="number" name="system.xp" value="{{actor.system.xp}}" min="0" step="1" title="{{actor.system.progression_xp}}">
                <button type="button" class="a2e-icon-btn" data-add2e-mx="xp" title="Ajouter de l'XP">+</button>
              </div>
            </div>
          {{/if}}

          {{#if actor.system.multiclasse.enabled}}
            <div class="a2e-field a2e-multiclass-field">
              <label>Titre</label>
              <input type="text" value="{{actor.system.titre}}" readonly title="{{actor.system.titre}}">
            </div>
          {{else}}
            <div class="a2e-field">
              <label>Titre</label>
              <input type="text" value="{{progressionCourante.title}}" readonly>
            </div>
          {{/if}}

          <div class="a2e-field">
            <label>Alignement</label>
            <select name="system.alignement">
              {{#each alignementsDisponibles as |algn|}}
                <option value="{{algn}}" {{#if (eq ../actor.system.alignement algn)}}selected{{/if}}>{{algn}}</option>
              {{/each}}
            </select>
          </div>

          <div class="a2e-field">
            <label>Mouvement</label>
            <input type="text" value="{{#if system.movement}}{{system.movement}}{{else}}{{actor.system.movement}}{{/if}} m" readonly>
          </div>

          <div class="a2e-field">
            <label>PV max</label>
            <input type="text" value="{{actor.system.points_de_coup}}" readonly>
          </div>

          <div class="a2e-field">
            <label>PV courant</label>
            <input type="number" name="system.pdv" value="{{actor.system.pdv}}" class="pv-courant">
          </div>

          <div class="a2e-field">
            <label>CA</label>
            <input type="text" value="{{actor.system.ca_total}}" readonly>
          </div>

          <div class="a2e-field">
            <label>THAC0</label>
            <input type="text" value="{{add2eBestThaco actor combatDefense.thaco}}" readonly title="Meilleur THAC0 parmi les classes actives du multiclassage.">
          </div>

        </div>
      </div>
    </header>
