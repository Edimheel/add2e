    <header class="a2e-header">
      <div>
        <img class="a2e-portrait" src="{{actor.img}}" alt="Portrait du personnage" data-edit="img">
      </div>

      <div>
        <div class="a2e-name-line">
          <input class="a2e-name" type="text" name="name" value="{{actor.name}}" aria-label="Nom du personnage">

          <div class="a2e-field a2e-player-top">
            <label>Joueur</label>
            <input type="text" name="system.nom_joueur" value="{{actor.system.nom_joueur}}">
          </div>
        </div>

        <div class="a2e-id-grid" style="grid-template-columns:minmax(250px,2fr) minmax(110px,.9fr) minmax(118px,.95fr) minmax(155px,1.2fr) minmax(90px,.75fr);">
          {{#if classProgression.enabled}}
            <div class="a2e-field a2e-class-progression-field" style="grid-column:span 2;min-width:0;">
              <label>Classe</label>
              <input type="text" value="{{actor.system.classe}}" readonly title="{{actor.system.classe}}">
            </div>
          {{else}}
            <div class="a2e-field" style="grid-column:span 2;min-width:0;">
              <label>Classe</label>
              <input type="text" name="system.classe" value="{{actor.system.classe}}">
            </div>
          {{/if}}

          <div class="a2e-field">
            <label>Race</label>
            <input type="text" name="system.race" value="{{actor.system.race}}">
          </div>

          {{#if classProgression.enabled}}
            <div class="a2e-field a2e-class-progression-field" style="min-width:0;">
              <label>Niveau</label>
              <div class="a2e-multiclass-inline" style="display:flex;align-items:center;gap:3px;min-width:0;white-space:nowrap;">
                {{#each classProgression.classes as |cls|}}
                  <input type="number"
                         name="{{#if ../classProgression.isMulticlass}}add2e.classProgression.{{cls.itemId}}.level{{else}}system.niveau{{/if}}"
                         value="{{cls.level}}"
                         data-class-id="{{cls.itemId}}"
                         data-class-progression-field="level"
                         min="1"
                         step="1"
                         style="min-width:0;flex:1 1 0;text-align:center;padding:4px 2px;"
                         title="{{cls.name}} — niveau">
                  {{#unless @last}}<span aria-hidden="true" style="color:var(--a2e-gold-dark);font-weight:900;">/</span>{{/unless}}
                {{/each}}
              </div>
            </div>
          {{else}}
            <div class="a2e-field">
              <label>Niveau</label>
              <input type="number" name="system.niveau" value="{{actor.system.niveau}}" min="1">
            </div>
          {{/if}}

          {{#if classProgression.enabled}}
            <div class="a2e-field a2e-xp-field a2e-class-progression-field" style="min-width:0;">
              <label>XP</label>
              <div class="a2e-multiclass-inline" style="display:flex;align-items:center;gap:3px;min-width:0;white-space:nowrap;">
                {{#each classProgression.classes as |cls|}}
                  <input type="number"
                         name="{{#if ../classProgression.isMulticlass}}add2e.classProgression.{{cls.itemId}}.xp{{else}}system.xp{{/if}}"
                         value="{{cls.xp}}"
                         data-class-id="{{cls.itemId}}"
                         data-class-progression-field="xp"
                         min="0"
                         step="1"
                         style="min-width:0;flex:1 1 0;text-align:center;padding:4px 2px;font-size:.9em;"
                         title="{{cls.name}} — XP / prochain seuil : {{cls.nextXp}}">
                  {{#unless @last}}<span aria-hidden="true" style="color:var(--a2e-gold-dark);font-weight:900;">/</span>{{/unless}}
                {{/each}}
              </div>
            </div>
          {{else}}
            <div class="a2e-field a2e-xp-field">
              <label>XP</label>
              <div class="a2e-xp-inline">
                <input type="number" name="system.xp" value="{{actor.system.xp}}" min="0" step="1" title="{{actor.system.progression_xp}}">
                <button type="button" class="a2e-icon-btn" data-add2e-mx="xp" title="Ajouter de l'XP">+</button>
              </div>
            </div>
          {{/if}}

          {{#if classProgression.enabled}}
            <div class="a2e-field a2e-class-progression-field" style="grid-column:span 3;min-width:0;">
              <label>Titre</label>
              <div class="a2e-multiclass-titles" style="display:flex;align-items:center;gap:5px;min-width:0;white-space:nowrap;overflow:hidden;">
                {{#each classProgression.classes as |cls|}}
                  <span title="{{cls.name}}" style="min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1 1 0;text-align:center;font-weight:700;color:var(--a2e-gold-dark);">
                    {{#if cls.title}}{{cls.title}}{{else}}—{{/if}}
                  </span>
                  {{#unless @last}}<span aria-hidden="true" style="color:var(--a2e-gold-dark);font-weight:900;">/</span>{{/unless}}
                {{/each}}
              </div>
            </div>
          {{else}}
            <div class="a2e-field" style="grid-column:span 3;min-width:0;">
              <label>Titre</label>
              <input type="text" value="{{progressionCourante.title}}" readonly>
            </div>
          {{/if}}

          <div class="a2e-field">
            <label>Alignement</label>
            <select name="system.alignement">
              {{#each alignementsDisponibles as |algn|}}
                <option value="{{algn}}" {{#if (eq ../actor.system.alignement algn)}}selected{{/if}}>{{algn}}</option>
              {{/each}}
            </select>
          </div>

          <div class="a2e-field">
            <label>Mouvement</label>
            <input type="text" value="{{#if system.movement}}{{system.movement}}{{else}}{{actor.system.movement}}{{/if}} m" readonly>
          </div>

          <div class="a2e-field">
            <label>PV max</label>
            <input type="text" value="{{actor.system.points_de_coup}}" readonly>
          </div>

          <div class="a2e-field">
            <label>PV courant</label>
            <input type="number" name="system.pdv" value="{{actor.system.pdv}}" class="pv-courant">
          </div>

          <div class="a2e-field">
            <label>CA</label>
            <input type="text" value="{{actor.system.ca_total}}" readonly>
          </div>

          <div class="a2e-field">
            <label>THAC0</label>
            <input type="text" value="{{add2eBestThaco actor combatDefense.thaco}}" readonly title="Meilleur THAC0 parmi les classes actives.">
          </div>

        </div>
      </div>
    </header>