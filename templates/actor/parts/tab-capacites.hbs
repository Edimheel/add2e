      <section class='a2e-tab-content tab tab-capacites {{#if (eq activeTab "capacites")}}active{{/if}}' data-group="primary" data-tab="capacites">
        <div class="a2e-grid-2">
          <div class="a2e-panel">
            <h2>Capacités activables</h2>
            <div class="a2e-panel-body">
              {{#if activeClassFeatures.length}}
                {{#each activeClassFeatures as |feature|}}
                  <div class="a2e-panel" style="box-shadow:none;">
                    <h3>
                      {{feature.name}}
                      {{#if feature._add2eClassName}}
                        <small class="a2e-muted"> — {{feature._add2eClassName}}</small>
                      {{/if}}
                      {{#if (gt feature.minLevel feature._add2eClassLevel)}}
                        <span class="a2e-muted" style="float:right;">Niveau {{feature.minLevel}}</span>
                      {{else}}
                        <span style="float:right;">{{#if feature.uses.label}}{{feature.uses.label}}{{else}}Actif{{/if}}</span>
                      {{/if}}
                    </h3>
                    <div class="a2e-panel-body a2e-small">
                      {{{feature.description}}}
                      <div class="a2e-actions" style="justify-content:flex-start;margin-top:8px;">
                        <button type="button"
                                class="a2e-btn blue add2e-feature-use"
                                data-feature-index="{{feature.__featureIndex}}"
                                data-feature-name="{{feature.name}}"
                                data-feature-key="{{feature.key}}"
                                data-on-use="{{feature.on_use}}">
                          <i class="fas fa-bolt"></i>&nbsp;Utiliser
                        </button>
                      </div>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <p class="a2e-muted">Aucune capacité de classe renseignée.</p>
              {{/if}}
            </div>
          </div>

          <div class="a2e-panel">
            <h2>Capacités passives</h2>
            <div class="a2e-panel-body">
              {{#if passiveClassFeatures.length}}
                {{#each passiveClassFeatures as |feature|}}
                  <div class="a2e-panel" style="box-shadow:none;">
                    <h3>
                      {{feature.name}}
                      {{#if feature._add2eClassName}}
                        <small class="a2e-muted"> — {{feature._add2eClassName}}</small>
                      {{/if}}
                      {{#if (gt feature.minLevel feature._add2eClassLevel)}}
                        <span class="a2e-muted" style="float:right;">Niveau {{feature.minLevel}}</span>
                      {{else}}
                        <span style="float:right;">Actif</span>
                      {{/if}}
                    </h3>
                    <div class="a2e-panel-body a2e-small">
                      {{{feature.description}}}
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <p class="a2e-muted">Aucune capacité passive.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </section>
