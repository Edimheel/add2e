      <section class='a2e-tab-content tab tab-sorts {{#if (eq activeTab "sorts")}}active{{/if}}' data-group="primary" data-tab="sorts">
        <div class="a2e-panel">
          <h2>
            Sorts
            {{#if add2eSpellSummaryRows.length}}
              <span class="a2e-spell-capacity-summary" title="Emplacements de sorts disponibles par liste">
                {{#each add2eSpellSummaryRows as |row|}}
                  {{#each row.levels as |level|}}
                    <span class="a2e-spell-capacity-pill">{{row.label}} N{{level.spellLevel}} {{level.count}}/{{level.max}}</span>
                  {{/each}}
                {{/each}}
              </span>
            {{/if}}
          </h2>
          <div class="a2e-panel-body">
            <div class="a2e-panel add2e-components-pouch-panel" style="box-shadow:none;">
              <h3>Sacoche de composants</h3>
              <div class="a2e-panel-body">
                {{#if listeSacocheComposants.length}}
                  <table class="a2e-table add2e-components-pouch-table">
                    <thead>
                      <tr>
                        <th>Composant</th>
                        <th style="width:90px;">Qté</th>
                        <th>Utilisé par</th>
                        <th style="width:120px;">Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {{#each listeSacocheComposants as |component|}}
                        <tr class="item add2e-component-row" data-item-id="{{component._id}}">
                          <td>
                            <img src="{{component.img}}" alt="{{component.name}}" style="width:26px;height:26px;border-radius:4px;object-fit:cover;vertical-align:middle;margin-right:6px;">
                            <b>{{component.name}}</b>
                          </td>
                          <td>{{component.system.quantite}}</td>
                          <td>{{componentSpellNames component ../sortsParNiveau}}</td>
                          <td>
                            <div class="a2e-actions">
                              <a class="item-control item-edit a2e-action-icon a2e-action-edit" data-action="edit" data-item-id="{{component._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                              <a class="item-control item-delete a2e-action-icon a2e-action-delete" data-action="delete" data-item-id="{{component._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                            </div>
                          </td>
                        </tr>
                      {{/each}}
                    </tbody>
                  </table>
                  <p class="a2e-small"><b>Total composants :</b> {{add2eConsumablesSummary.sacocheQuantity}}</p>
                {{else}}
                  <p class="a2e-muted">Aucun composant dans la sacoche.</p>
                {{/if}}
              </div>
            </div>

            {{#if add2eObjectMagicItems.length}}
              <div class="a2e-panel add2e-object-magic-panel" style="box-shadow:none;">
                <h3>Objets magiques</h3>
                <div class="a2e-panel-body">
                  {{#each add2eObjectMagicItems as |item|}}
                    <div class="a2e-panel add2e-object-magic-item" style="box-shadow:none;margin-bottom:8px;">
                      <h3>
                        <img src="{{item.img}}" alt="{{item.name}}" style="width:26px;height:26px;border-radius:4px;object-fit:cover;vertical-align:middle;margin-right:6px;">
                        {{item.name}}
                        {{#if item.max}}
                          <span class="sort-memorize-badge" style="float:right;">Charges : {{item.charges}} / {{item.max}}</span>
                        {{/if}}
                      </h3>
                      <div class="a2e-panel-body">
                        {{#if item.description}}
                          <div class="a2e-small sort-description-content" style="margin-bottom:8px;">
                            {{{item.description}}}
                          </div>
                        {{/if}}
                        <table class="sort-table add2e-object-magic-table">
                          <thead>
                            <tr>
                              <th style="width:42px;"></th>
                              <th>Pouvoir</th>
                              <th style="width:90px;">Coût</th>
                              <th style="width:120px;">Charges</th>
                            </tr>
                          </thead>
                          <tbody>
                            {{#each item.powers as |power|}}
                              {{#if power.onUse}}
                                <tr class="sort-row add2e-object-magic-power-row" data-sort-id="{{power.id}}">
                                  <td class="sort-drag">
                                    <img class="sort-cast-img" data-sort-id="{{power.id}}" src="{{power.img}}" title="Activer {{power.name}}" draggable="true" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                                  </td>
                                  <td>
                                    <a class="sort-name-link toggle-sort-desc-chat" data-sort-id="{{power.id}}" title="Afficher / masquer la description">{{power.name}}</a>
                                  </td>
                                  <td>{{#if power.cost}}{{power.cost}}{{else}}—{{/if}}</td>
                                  <td>{{#if power.max}}{{power.charges}} / {{power.max}}{{else}}—{{/if}}</td>
                                </tr>
                                <tr id="desc-chat-{{power.id}}" class="sort-description">
                                  <td colspan="4" class="sort-description-fullcell">
                                    <div class="a2e-small sort-description-content">
                                      {{{power.description}}}
                                    </div>
                                  </td>
                                </tr>
                              {{/if}}
                            {{/each}}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  {{/each}}
                </div>
              </div>
            {{else}}
              {{#if add2eObjectMagicPowers.length}}
                <div class="a2e-panel add2e-object-magic-panel" style="box-shadow:none;">
                  <h3>Objets magiques</h3>
                  <div class="a2e-panel-body">
                    <table class="sort-table add2e-object-magic-table">
                      <thead>
                        <tr>
                          <th style="width:42px;"></th>
                          <th>Objet</th>
                          <th style="width:120px;">Charges</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each add2eObjectMagicPowers as |power|}}
                          {{#if power.onUse}}
                            <tr class="sort-row add2e-object-magic-power-row" data-sort-id="{{power.id}}">
                              <td class="sort-drag">
                                <img class="sort-cast-img" data-sort-id="{{power.id}}" src="{{power.img}}" title="Activer {{#if power.sourceItemName}}{{power.sourceItemName}}{{else}}{{power.name}}{{/if}}" draggable="true" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                              </td>
                              <td>
                                <a class="sort-name-link toggle-sort-desc-chat" data-sort-id="{{power.id}}" title="Afficher / masquer la description">{{#if power.sourceItemName}}{{power.sourceItemName}}{{else}}{{power.name}}{{/if}}</a>
                              </td>
                              <td>{{#if power.max}}{{power.charges}} / {{power.max}}{{else}}—{{/if}}</td>
                            </tr>
                            <tr id="desc-chat-{{power.id}}" class="sort-description">
                              <td colspan="3" class="sort-description-fullcell">
                                <div class="a2e-small sort-description-content">
                                  {{#if power.sourceItemDescription}}{{{power.sourceItemDescription}}}{{else}}{{{power.description}}}{{/if}}
                                </div>
                              </td>
                            </tr>
                          {{/if}}
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                </div>
              {{/if}}
            {{/if}}

            {{#if add2eSpellLevels.length}}
              {{#each add2eSpellLevels as |level|}}
                <div class="a2e-panel" style="box-shadow:none;">
                  <h3>Niveau {{level.spellLevel}}</h3>
                  <div class="a2e-panel-body">
                    {{#each level.groups as |group|}}
                      <div class="a2e-panel add2e-spell-list-group" style="box-shadow:none;margin-bottom:8px;">
                        <h3>
                          {{group.title}}
                          {{#if group.counter.max}}
                            <span class="sort-memorize-badge">{{group.counter.label}} : {{group.counter.count}} / {{group.counter.max}}</span>
                          {{/if}}
                        </h3>
                        <div class="a2e-panel-body">
                          {{#if group.sorts.length}}
                            <table class="sort-table">
                              <thead>
                                <tr>
                                  <th style="width:130px;">Préparer</th>
                                  <th style="width:42px;"></th>
                                  <th>Sort</th>
                                  <th style="width:140px;">École</th>
                                  <th style="width:70px;">Type</th>
                                  <th style="width:260px;">Composants</th>
                                  <th style="width:90px;">Actions</th>
                                </tr>
                              </thead>
                              <tbody>
                                {{#each group.sorts as |sort|}}
                                  <tr class="sort-row" data-sort-id="{{sort.id}}">
                                    <td>
                                      {{#if sort.entries.length}}
                                        {{#each sort.entries as |entry|}}
                                          {{#if (eq entry.key group.key)}}
                                            <div class="add2e-spell-prep-entry" style="white-space:nowrap;">
                                              <a class="a2e-action-icon a2e-action-remove a2e-spell-entry-minus" data-sort-id="{{sort.id}}" data-entry-key="{{entry.key}}" title="Retirer une préparation {{entry.label}}"><i class="fas fa-minus-circle"></i></a>
                                              <span class="sort-memorize-badge" data-add2e-memorized-count="{{entry.count}}">{{entry.count}}</span>
                                              <a class="a2e-action-icon a2e-action-add a2e-spell-entry-plus" data-sort-id="{{sort.id}}" data-entry-key="{{entry.key}}" title="Ajouter une préparation {{entry.label}}"><i class="fas fa-plus-circle"></i></a>
                                            </div>
                                          {{/if}}
                                        {{/each}}
                                      {{else}}
                                        <span class="a2e-muted">—</span>
                                      {{/if}}
                                    </td>
                                    <td class="sort-drag">
                                      <img class="sort-cast-img" data-sort-id="{{sort.id}}" src="{{sort.img}}" title="Lancer {{sort.name}}" draggable="true" style="width:34px;height:34px;border-radius:5px;object-fit:cover;cursor:pointer;">
                                    </td>
                                    <td>
                                      <a class="sort-name-link toggle-sort-desc-chat" data-sort-id="{{sort.id}}" title="Afficher / masquer la description">{{sort.name}}</a>
                                      {{#if sort.listLabel}}<div class="a2e-muted a2e-small">{{sort.listLabel}}</div>{{/if}}
                                    </td>
                                    <td>{{sort.ecole}}</td>
                                    <td>{{spellComponentTypes sort}}</td>
                                    <td>{{spellMaterialComponents sort}}</td>
                                    <td>
                                      <div class="a2e-actions">
                                        <a class="a2e-action-icon a2e-action-edit sort-edit" data-sort-id="{{sort.id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                                        <a class="a2e-action-icon a2e-action-delete sort-delete" data-sort-id="{{sort.id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
                                      </div>
                                    </td>
                                  </tr>
                                  <tr id="desc-chat-{{sort.id}}" class="sort-description">
                                    <td colspan="7" class="sort-description-fullcell">
                                      <div class="a2e-small sort-description-content">
                                        {{{sort.description}}}
                                        {{#if sort.composantes}}<div><b>Composantes :</b> {{sort.composantes}}</div>{{/if}}
                                        <div><b>Composants requis :</b> {{spellMaterialComponents sort}}</div>
                                        {{#if sort.temps_incantation}}<div><b>Incantation :</b> {{sort.temps_incantation}}</div>{{/if}}
                                        {{#if sort.portee}}<div><b>Portée :</b> {{formatSortChamp sort.portee}}</div>{{/if}}
                                        {{#if sort.duree}}<div><b>Durée :</b> {{formatSortChamp sort.duree}}</div>{{/if}}
                                      </div>
                                    </td>
                                  </tr>
                                {{/each}}
                              </tbody>
                            </table>
                          {{else}}
                            <p class="a2e-muted">Aucun sort de cette liste dans l'acteur.</p>
                          {{/if}}
                        </div>
                      </div>
                    {{/each}}
                  </div>
                </div>
              {{/each}}
            {{else}}
              <p class="a2e-muted">Aucun sort disponible.</p>
            {{/if}}
          </div>
        </div>
      </section>