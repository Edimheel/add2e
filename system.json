      "type": "Item"
    },
    {
      "name": "armes",
      "label": "Armes",
      "path": "packs/armes",
      "type": "Item"
    },
    {
      "name": "sorts",
      "label": "Sorts",
      "path": "packs/sorts",
      "type": "Item"
    },
    {
      "name": "armures",
      "label": "Armures",
      "path": "packs/armures",
      "type": "Item"
    },
    {
      "name": "objets-magiques",
